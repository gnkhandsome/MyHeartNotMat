}

.post-card-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
}

.post-action {
  padding: 8rpx 18rpx;
  font-size: 20rpx;
  line-height: 1;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.post-action.private-btn {
  color: #0f766e;
  background: linear-gradient(135deg, rgba(153, 246, 228, 0.86), rgba(167, 243, 208, 0.92));
  box-shadow: 0 8rpx 20rpx rgba(20, 184, 166, 0.22);
}

.post-action.shatter-btn {
  color: #fff;
  background: linear-gradient(135deg, #ff8a7a, #ff5c7a);
  box-shadow: 0 8rpx 20rpx rgba(255, 92, 122, 0.28);
}

.post-action.restore-btn {
  color: #0f766e;
  background: linear-gradient(135deg, rgba(153, 246, 228, 0.86), rgba(167, 243, 208, 0.92));
  box-shadow: 0 8rpx 20rpx rgba(20, 184, 166, 0.22);
}

/* 我的页面样式 */
.user-info {
  display: flex;
  align-items: center;
  padding: 40rpx;
  margin: 20rpx;
  border-radius: 20rpx;
  transition:
    background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.avatar-container {
  margin-right: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #f0f0f0;
}

.avatar-text {
  font-size: 50rpx;
  font-weight: bold;
  color: #333;
}

.user-details {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  display: block;
}

.mood {
  font-size: 28rpx;
  color: #666;
}

.user-data-tabs {
  padding: 24rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 24rpx;
}

.user-data-tab-row {
  display: flex;
  gap: 10rpx;
}

.user-data-tab {
  flex: 1;
  border-radius: 14rpx;
  padding: 18rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  background: rgba(15, 23, 42, 0.05);
}

.user-data-icon {
  font-size: 30rpx;
}

.user-data-text {
  font-size: 22rpx;
  color: #334155;
}

.mood-palette {
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 24rpx;
  transition:
    background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.mood-calendar {
  display: flex;
  flex-wrap: wrap;
  margin: -7.5rpx;
}

.mood-day {
  width: calc(14.28% - 15rpx);
  height: 50rpx;
  margin: 7.5rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 20rpx;
  color: white;
  transition: all 0.3s ease;
}

.mood-day:hover {
  transform: scale(1.1);
}

.mood-date {
  font-size: 16rpx;
}

.content-list {
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 24rpx;
  transition:
    background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.content-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.content-item:last-child {
  border-bottom: none;
}

.content-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.content-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.content-arrow {
  font-size: 32rpx;
  color: #999;
}

.blind-box {
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 24rpx;
  transition:
    background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.blind-box-content {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
  cursor: pointer;
}

.blind-box-card {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  perspective: 1000rpx;
}

.blind-box-front,
.blind-box-back {
  width: 100%;
  height: 100%;
  position: absolute;
  backface-visibility: hidden;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-radius: 20rpx;
  transition: transform 0.6s;
}

.blind-box-front {
  border-radius: 20rpx;
  transition: transform 0.6s;
}

.blind-box-back {
  color: white;
  transform: rotateY(180deg);
  padding: 20rpx;
  text-align: center;
  border-radius: 20rpx;
  transition: transform 0.6s;
}

.blind-box-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.blind-box-text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.blind-box-quote {
  font-size: 24rpx;
  line-height: 1.5;
  color: white;
}

.blind-box-card.flipping .blind-box-front {
  transform: rotateY(180deg);
}

.blind-box-card.flipping .blind-box-back {
  transform: rotateY(0deg);
}

.theme-setting {
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 24rpx;
  transition:
    background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.theme-tabs {
  display: flex;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
  overflow: hidden;
  background-color: #f0f0f0;
}

.theme-tab {
  flex: 1;
  padding: 15rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  transition:
    color 0.3s cubic-bezier(0.22, 1, 0.36, 1),
    background-color 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.theme-tab.active {
  background-color: #333;
  color: white;
}

.theme-list {
  display: flex;
  flex-wrap: wrap;
  margin: -10rpx;
}

.theme-item {
  width: calc(33.33% - 20rpx);
  margin: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: #f0f0f0;
  transition:
    transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
    background-color 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.theme-item:hover {
  transform: translateY(-5rpx);
}

.theme-color {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
}

.theme-name {
  font-size: 24rpx;
  color: #333;
}

/* 自定义底部导航栏 */
.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 10;
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
  transition:
    background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.fab-movable-area {
  position: fixed;
  inset: 0;
  z-index: 30;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
}

.fab-movable-view {
  width: 80rpx;
  height: 80rpx;
  pointer-events: auto;
}

.companion-trail-layer {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 25;
}

.companion-trail-dot {
  position: absolute;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.92), rgba(147, 197, 253, 0.72));
  box-shadow: 0 0 12rpx rgba(125, 211, 252, 0.35);
  animation: companion-trail-fade 0.32s ease-out forwards;
}

.tabbar-item.active {
  font-weight: bold;
}

.tabbar-icon {
  font-size: 32rpx;
  display: block;
}

.tabbar-text {
  font-size: 24rpx;
  color: #666;
}

.tabbar-item.active .tabbar-text {
  font-weight: bold;
}

.breathing-guide-panel {
  position: fixed;
  left: 22rpx;
  right: 22rpx;
  bottom: calc(112rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx;
  padding: 18rpx 20rpx;
  z-index: 1100;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.breathing-guide-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #6b7280;
}

.breathing-guide-phase {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.breathing-guide-tip {
  font-size: 20rpx;
  color: #9ca3af;
}

.companion-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.companion-sprite {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 26rpx rgba(59, 130, 246, 0.2);
  animation: companion-float 2.8s ease-in-out infinite;
  transition: none;
}

.companion-sprite.dragging {
  animation: none;
  transition: none;
}

.companion-sprite.cloud {
  background: radial-gradient(circle at 30% 26%, rgba(255, 255, 255, 0.96), rgba(191, 219, 254, 0.88));
}

.companion-sprite.core {
  background: radial-gradient(circle at 30% 30%, rgba(224, 231, 255, 0.95), rgba(99, 102, 241, 0.9));
}

.companion-eye {
  position: absolute;
  top: 22rpx;
  width: 5rpx;
  height: 7rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.75);
}

.companion-eye.left {
  left: 18rpx;
}

.companion-eye.right {
  right: 18rpx;
}

.companion-sprite.state-happy {
  filter: brightness(1.08) saturate(1.08);
  animation-duration: 2s;
}

.companion-sprite.state-sad {
  filter: grayscale(0.16) brightness(0.92);
  transform: scale(0.92);
}

.companion-sprite.state-breathing {
  animation: companion-breathing 3s ease-in-out infinite;
}

.companion-sprite.drag-level-1 {
  transform: scaleX(1.04) scaleY(0.97);
}

.companion-sprite.drag-level-2 {
  transform: scaleX(1.1) scaleY(0.92);
}

.companion-sprite.drag-level-3 {
  transform: scaleX(1.16) scaleY(0.86);
}

.companion-sprite.is-shy {
  transform: translateX(-8rpx) scale(0.94);
}

.companion-sprite.is-shy.drag-level-1 {
  transform: translateX(-8rpx) scaleX(1.02) scaleY(0.92);
}

.companion-sprite.is-shy.drag-level-2 {
  transform: translateX(-8rpx) scaleX(1.08) scaleY(0.88);
}

.companion-sprite.is-shy.drag-level-3 {
  transform: translateX(-8rpx) scaleX(1.14) scaleY(0.82);
}

.companion-bubble {
  position: absolute;
  right: 52rpx;
  top: -8rpx;
  min-width: 180rpx;
  max-width: 320rpx;
  padding: 10rpx 14rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #374151;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.12);
  animation: companion-bubble-in 0.2s ease-out;
}

.companion-bubble::after {
  content: '';
  position: absolute;
  right: -8rpx;
  top: 16rpx;
  width: 0;
  height: 0;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  border-left: 10rpx solid rgba(255, 255, 255, 0.96);
}

@keyframes companion-float {
  0%,
  100% { margin-top: 0; }
  50% { margin-top: -6rpx; }
}

@keyframes companion-breathing {
  0%,
  100% { transform: scale(1); filter: brightness(1); }
  50% { transform: scale(1.18); filter: brightness(1.08); }
}

@keyframes companion-bubble-in {
  from {
    opacity: 0;
    transform: translateY(6rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes companion-trail-fade {
  0% {
    opacity: 0.75;
    transform: translate(-50%, -50%) scale(1);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.4);
  }
}

