<view class="container" style="background-color: {{theme.bgColor}};">
  <!-- 导航栏 -->
  <view class="navigation-bar" style="background-color: {{theme.bgColor}};">
    <view class="nav-left" bindtap="goBack">
      <text class="nav-back-icon">←</text>
    </view>
    <text class="nav-title" style="color: {{textPalette.title}};">通知</text>
    <view class="nav-right">
      <text class="nav-action" style="color: {{theme.primaryColor}};" bindtap="onMarkAllRead">全部已读</text>
      <text class="nav-action" style="color: {{theme.primaryColor}};" bindtap="onDeleteAll">清空</text>
    </view>
  </view>

  <!-- 通知列表 -->
  <scroll-view 
    class="notification-list"
    scroll-y="true"
    refresher-enabled="true"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <!-- 空状态 -->
    <view wx:if="{{notifications.length === 0}}" class="empty-state">
      <text class="empty-icon">🔔</text>
      <text class="empty-text" style="color: {{textPalette.subtitle}};">暂无通知</text>
    </view>

    <!-- 通知列表 -->
    <view wx:else>
      <view wx:for="{{notifications}}" wx:key="id" class="notification-item {{item.read ? 'read' : ''}}">
        <view class="notification-avatar" style="background: linear-gradient(145deg, {{theme.primaryColor}}, {{theme.primaryColor}}cc);">
          <text wx:if="{{item.type === 'like'}}" class="notification-type-icon">❤️</text>
          <text wx:elif="{{item.type === 'favorite'}}" class="notification-type-icon">⭐</text>
          <text wx:elif="{{item.type === 'comment'}}" class="notification-type-icon">💬</text>
        </view>
        <view class="notification-content">
          <text class="notification-sender" style="color: {{textPalette.title}};">{{item.senderNickname}}</text>
          <text class="notification-text" style="color: {{textPalette.body}};">
            {{item.type === 'like' ? '点赞了你的动态' : item.type === 'favorite' ? '收藏了你的动态' : '评论了你的动态'}}
          </text>
          <text class="notification-time" style="color: {{textPalette.subtitle}};">{{item.time}}</text>
        </view>
        <view class="notification-actions">
          <text wx:if="{{!item.read}}" class="notification-unread-dot"></text>
          <text class="notification-delete" style="color: {{textPalette.subtitle}};" bindtap="onDeleteNotification" data-id="{{item.id}}">删除</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
