.hanging-ornament {
  width: 58rpx;
  min-height: 64rpx;
  border-radius: 18rpx;
  padding: 8rpx 6rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform-origin: top center;
  animation: ornament-sway 2.8s ease-in-out infinite;
}

.hanging-ornament.ornament-knot {
  background: linear-gradient(145deg, rgba(251, 113, 133, 0.95), rgba(239, 68, 68, 0.82));
}

.hanging-ornament.ornament-bell {
  background: linear-gradient(145deg, rgba(250, 204, 21, 0.94), rgba(245, 158, 11, 0.84));
}

.hanging-ornament.ornament-leaf {
  background: linear-gradient(145deg, rgba(16, 185, 129, 0.9), rgba(5, 150, 105, 0.82));
}

.hanging-ornament.ornament-feather {
  background: linear-gradient(145deg, rgba(129, 140, 248, 0.92), rgba(99, 102, 241, 0.82));
}

.hanging-ornament-core {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 600;
