<view class="container ambient-breathing scene-{{activeScene}} ambient-time-{{ambientTimeSlot}} {{isRainModeEnabled ? 'rain-mode-on' : ''}} {{rainPerfLevel === 'low' ? 'rain-perf-low' : ''}} {{isSceneEntering ? 'scene-entering' : ''}}" style="background-color: {{theme.bgColor}}; background-size: cover; background-position: center;">
  <canvas
    wx:if="{{isShredCanvasVisible}}"
    id="homeShredCanvas"
    type="2d"
    class="shred-canvas"
  ></canvas>
  
  <!-- 自定义背景蒙层（仅在写作页面显示） -->
  <view wx:if="{{customBackground && currentPage === 0}}" class="custom-background-overlay"></view>

  <view wx:if="{{currentPage === 0}}" class="immersive-scene-overlay" aria-hidden="true">
    <view
      wx:for="{{sceneParticles}}"
      wx:key="id"
      class="scene-particle kind-{{item.kind}}"
      style="left: {{item.left}}%; top: {{item.top}}%; width: {{item.size}}rpx; height: {{item.size}}rpx; opacity: {{item.opacity}}; animation-duration: {{item.duration}}ms; animation-delay: {{item.delay}}ms;"
    ></view>
  </view>

  <view wx:if="{{isRainModeEnabled && currentPage === 0}}" class="rain-overlay" aria-hidden="true">
    <view
      wx:for="{{rainDrops}}"
      wx:key="id"
      class="rain-drop"
      style="left: {{item.left}}%; height: {{item.height}}rpx; width: {{item.width}}rpx; animation-duration: {{item.duration}}ms; animation-delay: {{item.delay}}ms; opacity: {{item.opacity}}; --rain-drift-x: {{item.driftX}}rpx; --rain-sway-amp: {{item.swayAmp}}rpx; --rain-sway-mid: {{item.swayMid}}rpx; --rain-tilt: {{item.tiltDeg}}deg;"
    ></view>
  </view>

  <view wx:if="{{currentPage === 0}}" class="ambient-time-layer slot-{{ambientTimeSlot}}" aria-hidden="true"></view>

  <view wx:if="{{isSceneEntering && currentPage === 0}}" class="scene-enter-curtain" aria-hidden="true"></view>
  <view
    wx:if="{{showSceneRestoreHint && currentPage === 0}}"
    class="scene-restore-hint scene-{{sceneRestoreHintScene}}"
    aria-live="polite"
  >
    {{sceneRestoreHintText}}
  </view>

  <!-- 页面容器（改为非 swiper，彻底禁用跟手横滑） -->
  <view class="page-swiper">
    <!-- 心语页面 -->
    <view class="page-wrapper {{currentPage === 0 ? 'page-active' : ''}}">
      <view class="page-container">
        <!-- 写作场景 -->
        <view class="writing-workspace theme-{{activeThemeType}} {{isWritingFocused ? 'writing-focused' : ''}} {{writingLightEnabled ? 'writing-light-enabled' : ''}}">

          
          <view class="writing-left-rail">
            <view id="toolEntryTheme" class="left-entry-card {{activeToolPanel === 'theme' ? 'is-active' : ''}}" bindtap="onTapToolTheme">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'theme' ? 14 : 8}}rpx {{theme.primaryColor}});">🎨</text>
            </view>

            <view id="toolEntryOrnament" class="left-entry-card {{activeToolPanel === 'ornament' ? 'is-active' : ''}}" bindtap="onSelectHangingOrnament">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'ornament' ? 14 : 8}}rpx {{theme.primaryColor}});">🪢</text>
            </view>

            <view id="toolEntryBlindbox" class="left-entry-card {{activeToolPanel === 'blindbox' ? 'is-active' : ''}}" bindtap="onTapToolBlindBox">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'blindbox' ? 14 : 8}}rpx {{theme.primaryColor}});">🎁</text>
            </view>

            <view class="left-entry-card" bindtap="toggleBreathingGuide">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{isBreathingActive ? 14 : 8}}rpx {{theme.primaryColor}});">🧘</text>
            </view>

            <view class="left-entry-card post-private-card">
              <switch
                checked="{{isPostPrivate}}"
                color="{{theme.primaryColor}}"
                bindchange="onPostPrivateChange"
              />
              <text class="post-private-label" style="color: {{textPalette.subtitle}};">本地私密</text>
            </view>
          </view>

          <view class="writing-main">
            <view wx:if="{{writingLightEnabled}}" class="writing-light-fx-layer" aria-hidden="true">
              <view class="writing-light-beam" style="{{writingLightBeamStyle}}"></view>
              <view class="writing-light-glow" style="{{writingLightGlowStyle}}"></view>
            </view>

            <view class="writing-paper {{activePostType}}" style="background-color: {{theme.cardColor}}; {{customBackground ? 'background-image: url(' + customBackground + ')' : 'background-image: linear-gradient(160deg, ' + theme.cardColor + ', ' + theme.bgColor + ')'}}; background-size: cover; background-position: center; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
              <view class="paper-header">
                <view class="paper-date-line" style="border-color: {{paperDateLineBorderColor}}; box-shadow: 0 0 20rpx {{paperDateLineShadowColor}};">
                  <text class="paper-date" style="color: {{textPalette.subtitle}};">{{writingDateText}}</text>
                  <text class="paper-subtitle {{isAmbientSubtitleAnimating ? 'is-updating' : ''}}" style="color: {{textPalette.subtitle}};">{{writingAmbientSubtitle}}</text>
                </view>
                <view class="hanging-hook-zone {{isOrnamentHookHighlighted ? 'is-highlighted' : ''}}" aria-label="挂件挂钩区域">
                  <view class="hanging-hook"></view>
                  <view class="hanging-line"></view>
                  <view class="hanging-ornament ornament-{{selectedHangingOrnament}}" style="animation-duration: {{ornamentSwayDuration}}s;">
                    <text class="hanging-ornament-core">{{hangingOrnamentSymbol}}</text>
                    <view class="hanging-tassels">
                      <view class="ornament-tassel-strand left"></view>
                      <view class="ornament-tassel-strand center"></view>
                      <view class="ornament-tassel-strand right"></view>
                    </view>
                  </view>
                  <text class="hanging-ornament-label" style="color: {{textPalette.subtitle}};">{{hangingOrnamentLabel}}</text>
                </view>
              </view>

              <scroll-view class="paper-body-scroll type-{{activePostType}}" scroll-y="true" scrollbar-hidden="true" style="background: linear-gradient(to bottom, {{theme.cardColor}}, {{theme.bgColor}});">
                <view class="paper-body {{isPostShattering ? 'post-shattering' : ''}} {{isWritingFocused ? 'writing-focused' : ''}} type-{{activePostType}}" style="background: linear-gradient(160deg, {{theme.cardColor}}, {{theme.bgColor}});">
                  <!-- 主标题输入框 -->
                  <view class="post-title-container">
                    <input
                      class="post-title-input"
                      placeholder="标题"
                      placeholder-style="color: {{textPalette.tertiary}};"
                      value="{{postTitle}}"
                      bindinput="onPostTitleInput"
                      bindfocus="onPostFocus"
                      bindblur="onPostBlur"
                      style="color: {{textPalette.title}};"
                      maxlength="20"
                    />
                  </view>
                  
                  <!-- 内容输入框 -->
                  <textarea
                    id="homePostInputField"
                    class="paper-textarea input-{{activePostType}}"
                    placeholder="{{postPlaceholder}}"
                    placeholder-style="color: {{textPalette.tertiary}};"
                    value="{{postContent}}"
                    bindinput="onPostInput"
                    bindfocus="onPostFocus"
                    bindblur="onPostBlur"
                    style="color: {{textPalette.body}};"
                    maxlength="-1"
                  ></textarea>

                  <!-- 地址输入框和发布按钮 -->
                  <view class="paper-footer-bar">
                    <view class="location-input-wrapper">
                      <text class="location-icon">📍</text>
                      <input
                        class="post-location-input"
                        placeholder="位置"
                        placeholder-style="color: {{textPalette.tertiary}};"
                        value="{{postLocation}}"
                        bindinput="onPostLocationInput"
                        style="color: {{textPalette.body}};"
                        maxlength="50"
                      />
                    </view>
                    <view
                      class="paper-publish-btn {{postContent && postContent.trim().length > 0 ? 'enabled' : ''}}"
                      bindtap="onPackagePost"
                      style="{{postContent && postContent.trim().length > 0 ? 'background: ' + publishBtnBgColor + '; border-color: ' + publishBtnTextColor + '; box-shadow: 0 0 20rpx ' + paperDateLineShadowColor + ';' : ''}}"
                    >
                      <text class="publish-btn-icon">📤</text>
                      <text class="publish-btn-text" style="color: {{postContent && postContent.trim().length > 0 ? publishBtnTextColor : textPalette.subtitle}};">{{editingPostId ? (isPostPrivate ? '重新保存' : '重新发布') : (isPostPrivate ? '保存' : '发布')}}</text>
                    </view>
                  </view>
                </view>
              </scroll-view>

            </view>
          </view>

          <view class="writing-right-rail">
            <view id="toolEntryBackground" class="left-entry-card right-entry-card {{activeToolPanel === 'background' ? 'is-active' : ''}}" bindtap="onTapToolBackground">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'background' ? 14 : 8}}rpx {{theme.primaryColor}});">🖼️</text>
            </view>
            <view id="toolEntryScene" class="left-entry-card right-entry-card {{activeToolPanel === 'scene' ? 'is-active' : ''}}" bindtap="onTapToolScene">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'scene' ? 14 : 8}}rpx {{theme.primaryColor}});">🌤️</text>
            </view>

            <view id="toolEntryAudio" class="left-entry-card right-entry-card {{isAudioPlaying ? 'is-active' : ''}}" bindtap="toggleAudioPlay">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{isAudioPlaying ? 14 : 8}}rpx {{theme.primaryColor}});">{{isAudioPlaying ? '⏸' : '▶'}}</text>
            </view>

            <view id="toolEntryLight" class="left-entry-card right-entry-card {{activeToolPanel === 'light' ? 'is-active' : ''}}" bindtap="onTapToolLight">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'light' ? 14 : 8}}rpx {{theme.primaryColor}});">💡</text>
            </view>

            <view
              id="companionNestSlot"
              class="left-entry-card right-entry-card companion-nest-card {{companionNestHighlighted ? 'is-highlighted' : ''}}"
              bindtap="onTapCompanionNest"
            >
              <view class="companion-nest-shell">
                <view wx:if="{{companionInNest}}" class="companion-nest-resting-sprite {{companionVisualType}}" style="background-color: {{theme.primaryColor}};">
                  <view class="companion-eye left"></view>
                  <view class="companion-eye right"></view>
                </view>
                <text wx:else class="companion-nest-emoji">🏡</text>
              </view>
              <text class="companion-nest-label" style="color: {{textPalette.subtitle}};">{{companionInNest ? '休息中' : '点击回窝'}}</text>
            </view>
          </view>

          <view wx:if="{{activeToolPanel}}" class="mini-tool-mask" bindtap="closeToolPanel"></view>

          <!-- 左边面板组 -->
          <view wx:if="{{activeToolPanel === 'theme' || activeToolPanel === 'ornament' || activeToolPanel === 'blindbox' || activeToolPanel === 'package'}}" class="mini-tool-pop left panel-{{activeToolPanel}}" catchtap="onTapToolPanelBody" style="top: {{miniToolTopPx}}px; background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
            <view class="mini-tool-head">
              <text class="mini-tool-title" style="color: {{textPalette.title}};">{{activeToolPanel === 'theme' ? '主题设置' : (activeToolPanel === 'ornament' ? '挂件更换' : (activeToolPanel === 'blindbox' ? '解忧盲盒' : '完成写作'))}}</text>
              <text class="mini-tool-close" bindtap="closeToolPanel" style="color: {{theme.primaryColor}};">收起</text>
            </view>

            <view wx:if="{{activeToolPanel === 'theme'}}" class="mini-tool-body">
              <view class="theme-tabs compact" style="background-color: {{theme.cardColor}};">
                <view class="theme-tab {{activeThemeType === themeStyleTypes.FEMALE ? 'active' : ''}}" bindtap="switchThemeType" data-type="{{themeStyleTypes.FEMALE}}" style="background-color: {{activeThemeType === themeStyleTypes.FEMALE ? theme.primaryColor : ''}}; color: {{activeThemeType === themeStyleTypes.FEMALE ? textPalette.inverse : textPalette.title}};">
                  柔美
                </view>
                <view class="theme-tab {{activeThemeType === themeStyleTypes.MALE ? 'active' : ''}}" bindtap="switchThemeType" data-type="{{themeStyleTypes.MALE}}" style="background-color: {{activeThemeType === themeStyleTypes.MALE ? theme.primaryColor : ''}}; color: {{activeThemeType === themeStyleTypes.MALE ? textPalette.inverse : textPalette.title}};">
                  深邃
                </view>
              </view>
              <view class="theme-list compact">
                <view class="theme-item compact" wx:for="{{filteredThemes}}" wx:key="item.id" bindtap="selectTheme" data-theme="{{item}}">
                  <view class="theme-color" style="background-color: {{item.primaryColor}};">
                    <text class="theme-name">{{item.name}}</text>
                  </view>
                </view>
              </view>
            </view>

            <view wx:if="{{activeToolPanel === 'ornament'}}" class="mini-tool-body">
              <text class="ornament-panel-tip" style="color: {{textPalette.subtitle}};">点击选中直接更换，或长按拖到右上挂钩更换</text>
              <view class="ornament-option-list">
                <view
                  wx:for="{{hangingOrnamentOptions}}"
                  wx:key="key"
                  class="ornament-option-item {{selectedHangingOrnament === item.key ? 'active' : ''}}"
                  data-key="{{item.key}}"
                  bindtap="onChooseHangingOrnament"
                  bindlongpress="onOrnamentOptionLongPress"
                  catchtouchmove="onOrnamentOptionTouchMove"
                  bindtouchend="onOrnamentOptionTouchEnd"
                  bindtouchcancel="onOrnamentOptionTouchCancel"
                >
                  <view class="ornament-option-badge ornament-{{item.key}}">
                    <text class="ornament-option-symbol">{{item.symbol}}</text>
                  </view>
                  <text class="ornament-option-label">{{item.label}}</text>
                </view>
              </view>

              <!-- 风力强度调整 -->
              <view class="scene-intensity-section">
                <text class="scene-intensity-label" style="color: {{textPalette.subtitle}};">风力强度</text>
                <view class="scene-intensity-row compact">
                  <slider
                    class="scene-intensity-slider"
                    min="20"
                    max="100"
                    step="5"
                    value="{{sceneIntensity}}"
                    activeColor="{{theme.primaryColor}}"
                    backgroundColor="#E5E7EB"
                    block-size="16"
                    bindchanging="onSceneIntensityChange"
                    bindchange="onSceneIntensityChange"
                  />
                  <text class="scene-intensity-value" style="color: {{textPalette.subtitle}};">{{sceneIntensity}}%</text>
                </view>
              </view>
            </view>

            <view wx:if="{{activeToolPanel === 'blindbox'}}" class="mini-tool-body">
              <view class="blind-box-content" bindtap="onOpenBlindBoxFromPanel">
                <view class="blind-box-card {{isFlipping ? 'flipping' : ''}}">
                  <view class="blind-box-front" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
                    <text class="blind-box-icon {{blindBoxEntryShaking ? 'shake' : ''}}">🎁</text>
                    <text class="blind-box-text" style="color: {{textPalette.subtitle}};">点我抽一句</text>
                  </view>
                  <view class="blind-box-back" wx:if="{{showQuote}}" style="background-color: {{theme.primaryColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
                    <text class="blind-box-quote" style="color: {{textPalette.inverse}};">{{currentQuote}}</text>
                  </view>
                </view>
              </view>
            </view>

            <view wx:if="{{activeToolPanel === 'package'}}" class="mini-tool-body package-tool-grid">
              <view class="package-tool-item" data-action="save" bindtap="onPackageAction">
                <text class="package-tool-icon">💾</text>
                <text class="package-tool-label">{{editingPostId ? '重新保存到本地' : '保存到本地'}}</text>
              </view>
              <view class="package-tool-item" data-action="publish" bindtap="onPackageAction">
                <text class="package-tool-icon">📤</text>
                <text class="package-tool-label">{{editingPostId ? '重新发布到广场' : '发布到广场'}}</text>
              </view>
            </view>
          </view>

          <!-- 右边面板组 -->
          <view wx:if="{{activeToolPanel === 'background' || activeToolPanel === 'volume' || activeToolPanel === 'scene' || activeToolPanel === 'intensity' || activeToolPanel === 'light'}}" class="mini-tool-pop right panel-{{activeToolPanel}}" catchtap="onTapToolPanelBody" style="top: {{miniToolTopPx}}px; background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
            <view wx:if="{{activeToolPanel === 'background'}}" class="mini-tool-head">
              <text class="mini-tool-title" style="color: {{textPalette.title}};">自定义背景</text>
              <text class="mini-tool-close" bindtap="closeToolPanel" style="color: {{theme.primaryColor}};">收起</text>
            </view>

            <view wx:if="{{activeToolPanel === 'background'}}" class="mini-tool-body">
              <view wx:if="{{customBackground}}" class="custom-background-preview">
                <image src="{{customBackground}}" mode="aspectFill" class="preview-image"></image>
              </view>
              <view class="background-actions">
                <view class="background-action-btn" bindtap="onChooseBackground">
                  <text class="action-icon">📷</text>
                  <text class="action-text">选择图片</text>
                </view>
                <view wx:if="{{customBackground}}" class="background-action-btn" bindtap="onClearBackground">
                  <text class="action-icon">🗑️</text>
                  <text class="action-text">清除背景</text>
                </view>
              </view>
            </view>

            <view wx:if="{{activeToolPanel !== 'background'}}" class="mini-tool-head">
              <text class="mini-tool-title" style="color: {{textPalette.title}};">{{activeToolPanel === 'volume' ? '音量' : (activeToolPanel === 'scene' ? '天气场景' : (activeToolPanel === 'intensity' ? '强度' : '灯光'))}}</text>
              <text class="mini-tool-close" bindtap="closeToolPanel" style="color: {{theme.primaryColor}};">收起</text>
            </view>

            <view wx:if="{{activeToolPanel === 'volume'}}" class="mini-tool-body">
              <view class="audio-volume-row compact">
                <slider
                  class="audio-slider"
                  min="0"
                  max="100"
                  step="5"
                  value="{{audioVolume}}"
                  activeColor="{{theme.primaryColor}}"
                  backgroundColor="#E5E7EB"
                  block-size="16"
                  bindinput="onAudioVolumeChange"
                  bindchange="onAudioVolumeChange"
                />
                <text class="audio-volume-value" style="color: {{textPalette.subtitle}};">{{audioVolume}}%</text>
              </view>
            </view>

            <view wx:if="{{activeToolPanel === 'scene'}}" class="mini-tool-body">
              <view class="scene-type-grid">
                <view
                  wx:for="{{sceneOptions}}"
                  wx:key="key"
                  class="scene-type-chip scene-{{item.key}} {{activeScene === item.key ? 'active' : ''}}"
                  bindtap="onSceneChange"
                  data-scene="{{item.key}}"
                >
                  <text class="scene-type-chip-icon">{{item.icon}}</text>
                  <text class="scene-type-chip-label">{{item.label}}</text>
                </view>
              </view>
            </view>

            <view wx:if="{{activeToolPanel === 'light'}}" class="mini-tool-body mini-tool-body-light">
              <view class="writing-light-option-row writing-light-switch-row">
                <text class="writing-light-option-label" style="color: {{textPalette.subtitle}};">灯光</text>
                <switch
                  checked="{{writingLightEnabled}}"
                  color="{{theme.primaryColor}}"
                  bindchange="onWritingLightEnableChange"
                />
              </view>

              <view class="writing-light-option-row">
                <text class="writing-light-option-label" style="color: {{textPalette.subtitle}};">灯色</text>
                <view class="writing-light-chip-group">
                  <view class="writing-light-chip {{writingLightColorMode === 'warm' ? 'active' : ''}}" data-mode="warm" bindtap="onSwitchWritingLightColor">暖黄</view>
                  <view class="writing-light-chip {{writingLightColorMode === 'white' ? 'active' : ''}}" data-mode="white" bindtap="onSwitchWritingLightColor">白炙</view>
                </view>
              </view>
            </view>
          </view>

        </view>
      </view>
    </view>
    
    <!-- 广场页面 -->
    <view class="page-wrapper {{currentPage === 1 ? 'page-active' : ''}}">
      <view class="page-container">
        <!-- 新内容提示浮窗 -->
        <view wx:if="{{newPostCount > 0}}" class="new-post-tip" bindtap="loadNewPosts">
          <text class="new-post-tip-text">{{newPostCount}}条新动态，点击刷新</text>
        </view>
        
        <scroll-view 
          class="square-post-list" 
          scroll-y="true" 
          scrollbar-hidden="true"
          refresher-enabled="{{true}}"
          refresher-triggered="{{squareRefreshing}}"
          bindrefresherrefresh="onSquareRefresh"
        >
          <!-- 空状态 -->
          <view wx:if="{{squarePostList.length === 0}}" class="square-empty-state">
            <text class="square-empty-icon">🌱</text>
            <text class="square-empty-text" style="color: {{textPalette.subtitle}};">广场暂无动态</text>
            <view class="square-empty-action-btn" bindtap="goToHomeWrite" style="background: linear-gradient(135deg, {{theme.primaryColor}}, #8b5cf6);">
              <text class="square-empty-action-text">去发布第一条动态</text>
            </view>
          </view>

          <!-- 动态列表 -->
          <view wx:else>
            <view class="square-post-item" wx:for="{{squarePostList}}" wx:key="id" id="home-card-{{item.id}}" bindtap="onOpenSquarePostDetail" data-id="{{item.id}}" data-tab="square">
              <view class="square-post-header">
                <view class="square-user-avatar">
                  <image wx:if="{{item.avatar}}" class="square-avatar-image" src="{{item.avatar}}" mode="aspectFill"></image>
                  <view wx:else class="square-avatar-placeholder" style="background: linear-gradient(145deg, {{theme.primaryColor}}, {{theme.primaryColor}}cc);">
                    <text class="square-avatar-text" style="color: {{textPalette.inverse}};">{{item.nickname ? item.nickname.charAt(0) : '匿'}}</text>
                  </view>
                </view>
                <view class="square-user-info">
                  <text class="square-user-nickname" style="color: {{theme.primaryColor}};">{{item.nickname || '匿名用户'}}</text>
                </view>
              </view>

              <view class="square-post-content">
                <view class="square-post-content-inner">
                  <view wx:if="{{item.title}}" class="square-post-title" style="color: {{textPalette.title}};">
                    {{item.title}}
                  </view>
                  <view class="square-post-text" style="color: {{textPalette.title}}; opacity: 0.7;">{{item.content}}</view>
                  <view wx:if="{{item.location}}" class="square-post-location" style="color: {{textPalette.subtitle}};">📍 {{item.location}}</view>
                  <view wx:if="{{item.blindBoxQuote}}" class="square-post-quote" style="color: {{theme.primaryColor}};">「{{item.blindBoxQuote}}」</view>
                </view>
              </view>

              <view class="square-post-footer">
                <view class="square-post-footer-inner">
                  <view class="square-post-actions-group">
                    <view class="square-post-action like-action" catchtap="onToggleLike" data-id="{{item.id}}">
                      <text class="action-icon">{{item.isLiked ? '❤️' : '🤍'}}</text>
                    </view>
                    <view class="square-post-action collect-action" catchtap="onToggleCollect" data-id="{{item.id}}">
                      <text class="action-icon {{item.isCollected ? '' : 'white-star'}}">{{item.isCollected ? '⭐' : '⭐'}}</text>
                    </view>
                    <view class="square-post-action comment-action" catchtap="onOpenPostDetail" data-id="{{item.id}}" data-tab="square">
                      <text class="action-icon">💬</text>
                      <text class="action-text" style="color: {{textPalette.title}};">评论</text>
                    </view>
                  </view>
                  <text class="square-post-time-footer" style="color: {{textPalette.subtitle}};">{{item.time}}</text>
                </view>
              </view>

              <view class="square-post-divider"></view>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>
    
    <!-- 我的页面 -->
    <view class="page-wrapper {{currentPage === 2 ? 'page-active' : ''}}">
      <view class="page-container profile-page-container">
        <!-- 用户信息区 -->
        <view class="profile-user-info-section">
          <view class="profile-notification-wrapper">
            <view class="profile-notification-btn" bindtap="onProfileNotificationTap">
              <text class="profile-notification-icon">🔔</text>
            </view>
          </view>
          <view class="profile-avatar-wrapper">
            <view class="profile-avatar">
              <image wx:if="{{userInfo.avatar}}" class="profile-avatar-image" src="{{userInfo.avatar}}" mode="aspectFill"></image>
              <view wx:else class="profile-avatar-placeholder" style="background: linear-gradient(145deg, {{theme.primaryColor}}, {{theme.primaryColor}}cc);">
                <text class="profile-avatar-text">{{userInfo.nickname.charAt(0)}}</text>
              </view>
            </view>
            <view class="profile-avatar-edit-btn" bindtap="onEditUserInfo" style="background-color: {{theme.primaryColor}};">
              <text class="profile-edit-icon">🖌️</text>
            </view>
          </view>
          <view class="profile-user-details">
            <text class="profile-nickname" style="color: {{textPalette.title}};">{{userInfo.nickname}}</text>
            <text class="profile-mood" style="color: {{textPalette.subtitle}};">{{userInfo.mood}}</text>
          </view>
        </view>

        <!-- Tab 切换 -->
        <view class="profile-tabs-section">
          <view class="profile-tabs">
            <view class="profile-tab {{profileActiveTab === 'topics' ? 'active' : ''}}" bindtap="onProfileSwitchTab" data-tab="topics" style="{{profileActiveTab === 'topics' ? '--tab-active-color: ' + theme.primaryColor : ''}}">
              <text class="profile-tab-text" style="color: {{profileActiveTab === 'topics' ? theme.primaryColor : textPalette.body}};">我的发布</text>
            </view>
            <view class="profile-tab {{profileActiveTab === 'favorites' ? 'active' : ''}}" bindtap="onProfileSwitchTab" data-tab="favorites" style="{{profileActiveTab === 'favorites' ? '--tab-active-color: ' + theme.primaryColor : ''}}">
              <text class="profile-tab-text" style="color: {{profileActiveTab === 'favorites' ? theme.primaryColor : textPalette.body}};">我的收藏</text>
            </view>
          </view>
        </view>

        <!-- 滑动切换容器 -->
        <swiper 
          class="profile-swiper"
          current="{{profileActiveTab === 'topics' ? 0 : 1}}"
          bindchange="onProfileSwiperChange"
          duration="300"
        >
          <!-- 我的发布页面 -->
          <swiper-item>
            <view class="profile-content-section">
          <!-- 本地私密入口（固定） -->
          <view class="profile-private-entry" bindtap="onOpenPrivatePosts">
            <view class="profile-private-entry-left">
              <text class="profile-private-icon">🔒</text>
              <text class="profile-private-title" style="color: {{textPalette.title}};">本地私密</text>
            </view>
            <view class="profile-private-entry-right">
              <text class="profile-private-count" style="color: {{theme.primaryColor}};">{{privateContentCount}}</text>
              <text class="profile-private-arrow" style="color: {{textPalette.subtitle}};">›</text>
            </view>
          </view>
          
          <scroll-view 
            class="profile-content-list profile-content-list-no-bottom" 
            scroll-y="true" 
            scrollbar-hidden="true"
            refresher-enabled="{{true}}"
            refresher-triggered="{{profileTopicsRefreshing}}"
            bindrefresherrefresh="onProfileTopicsRefresh"
          >
            <!-- 空状态 -->
            <view wx:if="{{publicMyTopicsList.length === 0}}" class="profile-empty-state">
              <text class="profile-empty-text" style="color: {{textPalette.subtitle}};">暂无公开内容</text>
              <view class="profile-empty-action-btn" bindtap="goToHomeWrite" style="background: linear-gradient(135deg, {{theme.primaryColor}}, #8b5cf6);">
                <text class="profile-empty-action-text">去发布</text>
              </view>
            </view>

            <!-- 我的发布列表（公开） -->
            <view wx:else>
              <view wx:for="{{publicMyTopicsList}}" wx:key="id" class="square-post-item" bindtap="onProfileOpenPostDetail" data-id="{{item.id}}" data-type="topic">
                <view class="square-post-header">
                  <view class="square-user-avatar">
                    <image wx:if="{{userInfo.avatar}}" class="square-avatar-image" src="{{userInfo.avatar}}" mode="aspectFill"></image>
                    <view wx:else class="square-avatar-placeholder" style="background: linear-gradient(145deg, {{theme.primaryColor}}, {{theme.primaryColor}}cc);">
                      <text class="square-avatar-text" style="color: {{textPalette.inverse}};">{{userInfo.nickname.charAt(0)}}</text>
                    </view>
                  </view>
                  <view class="square-user-info">
                    <text class="square-user-nickname" style="color: {{theme.primaryColor}};">{{userInfo.nickname}}</text>
                  </view>
                </view>

                <view class="square-post-content">
                  <view class="square-post-content-inner">
                    <view wx:if="{{item.title}}" class="square-post-title" style="color: {{textPalette.title}};">
                      <view class="square-post-title-bar" style="background-color: {{theme.primaryColor}};"></view>
                      {{item.title}}
                    </view>
                    <view class="square-post-text" style="color: {{textPalette.title}}; opacity: 0.7;">{{item.content}}</view>
                    <view wx:if="{{item.location}}" class="square-post-location" style="color: {{textPalette.subtitle}};">📍 {{item.location}}</view>
                    <view wx:if="{{item.blindBoxQuote}}" class="square-post-quote" style="color: {{theme.primaryColor}};">「{{item.blindBoxQuote}}」</view>
                  </view>
                </view>

                <view class="square-post-footer">
                  <view class="square-post-footer-inner">
                    <view class="square-post-actions-group">
                      <view class="square-post-action" catchtap="onEditMyPost" data-id="{{item.id}}">
                        <text class="action-icon">✏️</text>
                        <text class="action-text" style="color: {{textPalette.title}};">编辑</text>
                      </view>
                      <view class="square-post-action" catchtap="onDeleteMyPost" data-id="{{item.id}}">
                        <text class="action-icon">�️</text>
                        <text class="action-text" style="color: {{textPalette.title}};">删除</text>
                      </view>
                    </view>
                    <text class="square-post-time-footer" style="color: {{textPalette.subtitle}};">{{item.time}}</text>
                  </view>
                </view>

                <view class="square-post-divider"></view>
              </view>
            </view>
          </scroll-view>
            </view>
          </swiper-item>

          <!-- 我的收藏页面 -->
          <swiper-item>
            <view class="profile-content-section">
          <scroll-view 
            class="profile-content-list profile-content-list-no-bottom" 
            scroll-y="true" 
            scrollbar-hidden="true"
            refresher-enabled="{{true}}"
            refresher-triggered="{{profileFavoritesRefreshing}}"
            bindrefresherrefresh="onProfileFavoritesRefresh"
          >
            <!-- 空状态 -->
            <view wx:if="{{profileFavoriteList.length === 0}}" class="profile-empty-state">
              <text class="profile-empty-text" style="color: {{textPalette.subtitle}};">你还没有收藏内容</text>
            </view>

            <!-- 我的收藏列表 -->
            <view wx:else>
              <view wx:for="{{profileFavoriteList}}" wx:key="id" class="square-post-item" bindtap="onProfileOpenSquarePostDetail" data-id="{{item.id}}">
                <view class="square-post-header">
                  <view class="square-user-avatar">
                  <image wx:if="{{item.avatar}}" class="square-avatar-image" src="{{item.avatar}}" mode="aspectFill"></image>
                  <view wx:else class="square-avatar-placeholder" style="background: linear-gradient(145deg, {{theme.primaryColor}}, {{theme.primaryColor}}cc);">
                    <text class="square-avatar-text" style="color: {{textPalette.inverse}};">{{item.nickname ? item.nickname.charAt(0) : '匿'}}</text>
                  </view>
                </view>
                  <view class="square-user-info">
                    <text class="square-user-nickname" style="color: {{theme.primaryColor}};">{{item.nickname || '匿名用户'}}</text>
                  </view>
                </view>

                <view class="square-post-content">
                  <view class="square-post-content-inner">
                    <view wx:if="{{item.title}}" class="square-post-title" style="color: {{textPalette.title}};">
                      <view class="square-post-title-bar" style="background-color: {{theme.primaryColor}};"></view>
                      {{item.title}}
                    </view>
                    <view class="square-post-text" style="color: {{textPalette.title}}; opacity: 0.7;">{{item.content}}</view>
                    <view wx:if="{{item.location}}" class="square-post-location" style="color: {{textPalette.subtitle}};">📍 {{item.location}}</view>
                    <view wx:if="{{item.blindBoxQuote}}" class="square-post-quote" style="color: {{theme.primaryColor}};">「{{item.blindBoxQuote}}」</view>
                  </view>
                </view>

                <view class="square-post-footer">
                  <view class="square-post-footer-inner">
                    <view class="square-post-actions-group">
                      <view class="square-post-action like-action" catchtap="onToggleLike" data-id="{{item.id}}">
                        <text class="action-icon">{{item.isLiked ? '❤️' : '🤍'}}</text>
                      </view>
                      <view class="square-post-action collect-action" catchtap="onToggleCollect" data-id="{{item.id}}">
                        <text class="action-icon {{item.isCollected ? '' : 'white-star'}}">{{item.isCollected ? '⭐' : '⭐'}}</text>
                      </view>
                      <view class="square-post-action comment-action" catchtap="onOpenPostDetail" data-id="{{item.id}}" data-tab="square">
                        <text class="action-icon">�</text>
                        <text class="action-text" style="color: {{textPalette.title}};">评论</text>
                      </view>
                    </view>
                    <text class="square-post-time-footer" style="color: {{textPalette.subtitle}};">{{item.time}}</text>
                  </view>
                </view>

                <view class="square-post-divider"></view>
              </view>
            </view>
          </scroll-view>
            </view>
          </swiper-item>
        </swiper>
      </view>
    </view>
  </view>

  <view wx:if="{{showPackageConfirmDialog}}" class="package-dialog-mask" bindtap="closePackageConfirmDialog">
    <view class="package-dialog-card" catchtap="onTapToolPanelBody" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
      <text class="package-dialog-title" style="color: {{textPalette.title}};">准备封装「{{pendingPackageLabel}}」</text>
      <text class="package-dialog-desc" style="color: {{textPalette.subtitle}};">选择要执行的操作</text>
      <view class="package-dialog-actions">
        <view class="package-dialog-btn ghost" bindtap="onSaveDraftPackage">存草稿</view>
        <view class="package-dialog-btn primary" bindtap="onConfirmPackageStart">确认封装</view>
      </view>
    </view>
  </view>

  <view wx:if="{{showPackagingAnimation}}" class="package-anim-mask" aria-live="polite">
    <view class="package-anim-card">
      <text class="package-anim-icon">📦</text>
      <text class="package-anim-text" style="color: {{textPalette.title}};">正在封装中...</text>
    </view>
  </view>

  <view wx:if="{{isOrnamentDragging}}" class="ornament-drag-layer" aria-hidden="true">
    <view class="ornament-drag-ghost ornament-{{ornamentDraggingKey}}" style="{{ornamentDragStyle}}">
      <text class="ornament-drag-ghost-symbol">{{ornamentDraggingSymbol}}</text>
    </view>
  </view>

  <view wx:if="{{showPackagePublishDialog}}" class="package-dialog-mask" bindtap="closePackagePublishDialog">
    <view class="package-dialog-card" catchtap="onTapToolPanelBody" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
      <text class="package-dialog-title" style="color: {{textPalette.title}};">封装完成</text>
      <text class="package-dialog-desc" style="color: {{textPalette.subtitle}};">选择保存方式</text>
      <view class="package-dialog-actions">
        <view class="package-dialog-btn ghost" bindtap="onSavePackagedLocal">存本地</view>
        <view class="package-dialog-btn primary" bindtap="onPublishPackagedPost">发布广场</view>
      </view>
    </view>
  </view>

  <!-- 保存成功弹窗 -->
  <view wx:if="{{showSaveSuccessDialog}}" class="package-dialog-mask" bindtap="closeSaveSuccessDialog">
    <view class="package-dialog-card" catchtap="onTapToolPanelBody" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
      <text class="package-dialog-title" style="color: {{textPalette.title}};">保存成功</text>
      <text class="package-dialog-desc" style="color: {{textPalette.subtitle}};">私密作品已保存</text>
      <view class="package-dialog-actions">
        <view class="package-dialog-btn primary" bindtap="onGoToPrivatePosts">去查看</view>
      </view>
    </view>
  </view>

  <!-- 呼吸岛屿启动界面 -->
  <view wx:if="{{showBreathingStartScreen}}" class="breathing-start-overlay">
    <view class="breathing-start-container">
      <text class="breathing-island-close" bindtap="stopBreathingGuide">✕</text>
      <text class="breathing-island-title">呼吸岛屿</text>
      <text class="breathing-island-subtitle">长按开始呼吸引导</text>
      <view class="breathing-start-button-container">
        <view class="breathing-start-progress-circle">
          <view class="breathing-start-progress" style="transform: rotate({{(breathingStartProgress / 100) * 360 - 90}}deg);"></view>
        </view>
        <view 
          class="breathing-start-button" 
          bindtouchstart="onBreathingStartTouchStart" 
          bindtouchend="onBreathingStartTouchEnd" 
          bindtouchcancel="onBreathingStartTouchEnd"
        >
          <text class="breathing-start-icon">🧘</text>
        </view>
      </view>
      <text class="breathing-island-tip">长按按钮开始，松手即可取消</text>
    </view>
  </view>

  <!-- 呼吸岛屿沉浸式引导 -->
  <view wx:if="{{isBreathingActive}}" class="breathing-island-overlay" bindtap="stopBreathingGuide">
    <text class="breathing-island-timer-fixed">{{breathingTimer}}</text>
    <view class="breathing-island-content" catchtap="onTapBreathingIsland">
      <view class="breathing-island-container">
        <text class="breathing-island-title">呼吸岛屿</text>
        <text class="breathing-island-round">第{{breathingDisplayRound}}轮</text>
        <text class="breathing-island-phase">{{breathingGuideText}}</text>
        <view class="breathing-island-phase-timer-container">
          <text wx:if="{{phaseTimer}}" class="breathing-island-phase-timer">{{phaseTimer}}</text>
        </view>
        <text class="breathing-island-tip">点击屏幕任意位置结束</text>
      </view>
    </view>
  </view>

  <view wx:if="{{!companionInNest}}" class="companion-trail-layer" aria-hidden="true">
    <view
      wx:for="{{companionTrailParticles}}"
      wx:key="id"
      class="companion-trail-dot"
      style="left: {{item.x}}px; top: {{item.y}}px; width: {{item.size}}rpx; height: {{item.size}}rpx; opacity: {{item.opacity}};"
    ></view>
  </view>

  <!-- 自定义底部导航栏（编辑态隐藏） -->
  <view wx:if="{{!editingPostId}}" class="custom-tabbar" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border-top: ' + theme.borderStyle : ''}};">
    <view class="tabbar-item {{currentPage === 0 ? 'active' : ''}}" bindtap="switchPage" data-page="0">
      <text class="tabbar-icon" style="color: {{currentPage === 0 ? theme.primaryColor : textPalette.subtitle}};">📝</text>
      <text class="tabbar-text" style="color: {{currentPage === 0 ? theme.primaryColor : textPalette.subtitle}};">写点</text>
    </view>
    <view class="tabbar-item {{currentPage === 1 ? 'active' : ''}}" bindtap="switchPage" data-page="1">
      <text class="tabbar-icon" style="color: {{currentPage === 1 ? theme.primaryColor : textPalette.subtitle}};">📱</text>
      <text class="tabbar-text" style="color: {{currentPage === 1 ? theme.primaryColor : textPalette.subtitle}};">动态</text>
    </view>
    <view class="tabbar-item {{currentPage === 2 ? 'active' : ''}}" bindtap="switchPage" data-page="2">
      <text class="tabbar-icon" style="color: {{currentPage === 2 ? theme.primaryColor : textPalette.subtitle}};">👤</text>
      <text class="tabbar-text" style="color: {{currentPage === 2 ? theme.primaryColor : textPalette.subtitle}};">我的</text>
    </view>
  </view>

  <!-- 编辑态底部操作（替代导航栏） -->
  <view wx:if="{{editingPostId}}" class="custom-tabbar tabbar-editing" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border-top: ' + theme.borderStyle : ''}};">
    <view class="tabbar-editing-exit" bindtap="onExitEditingTap" style="color: {{theme.primaryColor}};">
      退出编辑
    </view>
  </view>

  <view wx:if="{{!companionInNest}}" class="fab-movable-area" style="pointer-events: {{isCompanionSelected ? 'auto' : 'none'}};" catchtap="onTapScreenForCompanionMove">
    <view
      class="fab-movable-view"
      style="left: {{fabX}}px; top: {{fabY}}px;"
    >
      <view
        class="companion-wrapper"
        catchtap="onTapCompanion"
      >
        <view 
          class="companion-sprite {{companionVisualType}} state-{{companionState}} drag-level-{{companionDragLevel}} {{companionIsShy ? 'is-shy' : ''}} {{isCompanionDragging ? 'dragging' : ''}} {{companionTapFeedback ? 'tap-feedback' : ''}} {{isCompanionSelected ? 'selected' : ''}}" 
          style="background-color: {{theme.primaryColor}}; {{isCompanionSelected ? (isCompanionSelectedPulse ? 'box-shadow: 0 0 0 8rpx ' + companionSelectedShadow1Pulse + ', 0 0 32rpx ' + companionSelectedShadow2Pulse + ', 0 12rpx 30rpx ' + companionSelectedShadow3Pulse + ';' : 'box-shadow: 0 0 0 6rpx ' + companionSelectedShadow1 + ', 0 0 24rpx ' + companionSelectedShadow2 + ', 0 10rpx 26rpx ' + companionSelectedShadow3 + ';') : ''}}"
        >
            <view class="companion-eye left"></view>
            <view class="companion-eye right"></view>
          </view>
        <view wx:if="{{showCompanionBubble}}" class="companion-bubble side-{{companionBubbleSide}} vertical-{{companionBubbleVertical}}" style="background-color: {{theme.cardColor}}; color: {{textPalette.body}}; box-shadow: {{theme.shadow}};">{{companionBubbleText}}</view>
      </view>
    </view>
  </view>

  <!-- 自定义弹窗组件 -->
  <custom-toast id="customToast" />
</view>
