<view class="container" style="background-color: {{theme.bgColor}};">
  <canvas
    wx:if="{{isShredCanvasVisible}}"
    id="postShredCanvas"
    type="2d"
    class="shred-canvas"
  ></canvas>

  <view class="nav-bar" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border-bottom: ' + theme.borderStyle : ''}};">
    <view class="nav-item" bindtap="cancelPost" style="color: {{theme.primaryColor}};">清空</view>
    <view class="nav-title" style="color: {{theme.textColor}};">发布</view>
    <view class="nav-item" bindtap="publishPost" style="color: {{theme.primaryColor}};">发布</view>
  </view>

  <view class="input-container {{isPostShattering ? 'post-shattering' : ''}}" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; border-radius: {{theme.borderRadius}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
    <textarea
      id="postInputField"
      class="input"
      placeholder="写点不想留存的心事..."
      placeholder-style="color: #999;"
      value="{{postContent}}"
      bindinput="onPostInput"
      style="color: {{theme.textColor}};"
    ></textarea>
  </view>

  <view class="action-buttons" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; border-radius: {{theme.borderRadius}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
    <view class="action-button" bindtap="shatter">
      <text class="action-icon">&#x1F4A5;</text>
      <text class="action-text">粉碎</text>
    </view>
    <view class="action-button" bindtap="togglePrivacy">
      <text class="action-icon">{{isAnonymous ? '🙈' : '👁️'}}</text>
      <text class="action-text">{{isAnonymous ? '匿名' : '公开'}}</text>
    </view>
    <view class="action-button" bindtap="toggleLocation">
      <text class="action-icon">{{showLocation ? '📍' : '🚫'}}</text>
      <text class="action-text">{{showLocation ? '显示位置' : '隐藏位置'}}</text>
    </view>
  </view>

  <view class="list-section" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; border-radius: {{theme.borderRadius}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
    <view class="section-title">已发布内容</view>
    <view wx:if="{{myPostList.length === 0}}" class="empty">暂无内容</view>
    <view wx:for="{{myPostList}}" wx:key="id" id="post-card-{{item.id}}" class="record-card {{shatteringCardIds.includes(item.id) ? 'shattering' : ''}}">
      <view class="record-content" style="color: {{theme.textColor}};">{{item.content}}</view>
      <view class="record-footer">
        <text class="record-time">{{item.time}}</text>
        <view class="card-shatter-btn" bindtap="onShatterCard" data-id="{{item.id}}" data-type="post">粉碎</view>
      </view>
    </view>
  </view>

  <view class="list-section" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; border-radius: {{theme.borderRadius}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
    <view class="section-title">心情日记</view>
    <view wx:if="{{diaryList.length === 0}}" class="empty">暂无日记</view>
    <view wx:for="{{diaryList}}" wx:key="id" id="post-card-{{item.id}}" class="record-card {{shatteringCardIds.includes(item.id) ? 'shattering' : ''}}">
      <view class="record-content" style="color: {{theme.textColor}};">{{item.content}}</view>
      <view class="record-footer">
        <text class="record-time">{{item.time}}</text>
        <view class="card-shatter-btn" bindtap="onShatterCard" data-id="{{item.id}}" data-type="diary">粉碎</view>
      </view>
    </view>
  </view>
</view>