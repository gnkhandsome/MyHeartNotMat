.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
  transition: background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

/*
 * Z-INDEX MAP（写作页核心层级约定）
 * 5  : 沉浸粒子层（.immersive-scene-overlay）
 * 6  : 雨效层（.rain-overlay）
 * 7  : 时间氛围层（.ambient-time-layer）
 * 9  : 场景入场幕布（.scene-enter-curtain）
 * 10 : 写作主内容容器（.writing-main）
 * 25 : 小精灵拖尾层（.companion-trail-layer）
 * 30 : 小精灵拖拽层（.fab-movable-area）
 * 35 : 左右工具栏（.writing-left-rail / .writing-right-rail）
 * 60+: 面板遮罩与弹层（.mini-tool-mask / .mini-tool-pop）
 * 120: 拖拽幽灵态（如挂件拖拽层）
 *
 * 写作区局部层级（.writing-main 内）
 * 2 : 纸张主体（.writing-paper）
 * 3 : 灯光效果层（.writing-light-fx-layer）
 * 4 : 挂件挂钩层（.hanging-hook-zone）
 */

.container.rain-mode-on {
  background-image: linear-gradient(
    to bottom,
    rgba(255, 255, 255, 0.02),
    rgba(99, 102, 241, 0.04)
  );
}

.container.scene-sunny {
  background-image: linear-gradient(to bottom, rgba(253, 230, 138, 0.18), rgba(191, 219, 254, 0.08));
}

.container.scene-cloudy {
  background-image: linear-gradient(to bottom, rgba(203, 213, 225, 0.22), rgba(148, 163, 184, 0.08));
}

.container.scene-rainy {
  background-image: linear-gradient(to bottom, rgba(15, 23, 42, 0.12), rgba(99, 102, 241, 0.08));
}

.container.scene-windy {
  background-image: linear-gradient(to bottom, rgba(187, 247, 208, 0.16), rgba(147, 197, 253, 0.08));
}

.container.scene-snowy {
  background-image: linear-gradient(to bottom, rgba(226, 232, 240, 0.28), rgba(219, 234, 254, 0.12));
}

.container.scene-stream {
  background-image: linear-gradient(to bottom, rgba(186, 230, 253, 0.2), rgba(167, 243, 208, 0.1));
}

.container.scene-entering {
  animation: scene-enter-zoom 2.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.scene-enter-curtain {
  position: fixed;
  inset: 0;
  z-index: 9;
  pointer-events: none;
  background: radial-gradient(circle at 50% 45%, rgba(255, 255, 255, 0.08), rgba(15, 23, 42, 0.52));
  animation: scene-curtain-fade 2.4s ease-out forwards;
}

.scene-restore-hint {
  position: fixed;
  top: calc(20rpx + env(safe-area-inset-top));
  left: 50%;
  transform: translateX(-50%);
  z-index: 12;
  max-width: 78vw;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, rgba(51, 65, 85, 0.84), rgba(30, 41, 59, 0.72));
  box-shadow: 0 12rpx 30rpx rgba(71, 85, 105, 0.22);
  backdrop-filter: blur(8rpx);
  animation: scene-restore-hint-in 1.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.scene-restore-hint.scene-sunny {
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.88), rgba(249, 115, 22, 0.78));
}

.scene-restore-hint.scene-rainy {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.88), rgba(79, 70, 229, 0.78));
}

.scene-restore-hint.scene-stream {
  background: linear-gradient(135deg, rgba(20, 184, 166, 0.86), rgba(14, 165, 233, 0.78));
}

@keyframes scene-restore-hint-in {
  0% {
    opacity: 0;
    transform: translateX(-50%) translateY(-8rpx) scale(0.98);
  }
  16% {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateX(-50%) translateY(-4rpx) scale(1);
  }
}

.shred-canvas {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
  z-index: 9999;
}

.rain-overlay {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 15;
  overflow: hidden;
}

.immersive-scene-overlay {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 14;
  overflow: hidden;
}

.ambient-time-layer {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 16;
  opacity: 0.52;
  transform-origin: center center;
  will-change: opacity, transform;
}

.ambient-time-layer.slot-morning {
  background:
    radial-gradient(circle at 18% 14%, rgba(254, 240, 138, 0.26), rgba(254, 243, 199, 0)),
    linear-gradient(to bottom, rgba(255, 248, 220, 0.18), rgba(186, 230, 253, 0.08));
}

.ambient-time-layer.slot-dusk {
  background:
    radial-gradient(circle at 82% 12%, rgba(251, 146, 60, 0.24), rgba(254, 215, 170, 0)),
    linear-gradient(to bottom, rgba(253, 186, 116, 0.14), rgba(196, 181, 253, 0.1));
}

.ambient-time-layer.slot-night {
  background:
    radial-gradient(circle at 78% 10%, rgba(125, 211, 252, 0.2), rgba(30, 41, 59, 0)),
    linear-gradient(to bottom, rgba(30, 41, 59, 0.24), rgba(15, 23, 42, 0.16));
}

.ambient-breathing .ambient-time-layer {
  animation: ambient-time-breathe 12s ease-in-out infinite;
}

.scene-particle {
  position: absolute;
  border-radius: 999rpx;
  animation-name: scene-float;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
  will-change: transform, opacity;
}

.scene-particle.kind-sun {
  background: radial-gradient(circle, rgba(254, 240, 138, 0.95), rgba(250, 204, 21, 0.3));
}

.scene-particle.kind-cloud {
  background: radial-gradient(circle, rgba(241, 245, 249, 0.9), rgba(203, 213, 225, 0.34));
}

.scene-particle.kind-rain {
  width: 2rpx !important;
  border-radius: 999rpx;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0), rgba(191, 219, 254, 0.85));
}

.scene-particle.kind-wind {
  background: linear-gradient(90deg, rgba(187, 247, 208, 0), rgba(134, 239, 172, 0.68), rgba(187, 247, 208, 0));
  border-radius: 999rpx;
}

.scene-particle.kind-snow {
  background: radial-gradient(circle, rgba(255, 255, 255, 0.96), rgba(219, 234, 254, 0.5));
}

.scene-particle.kind-leaf {
  background: radial-gradient(circle at 30% 30%, rgba(187, 247, 208, 0.92), rgba(110, 231, 183, 0.5));
}

@keyframes scene-float {
  0% {
    transform: translate3d(0, -8rpx, 0);
    opacity: 0;
  }

  15% {
    opacity: 1;
  }

  100% {
    transform: translate3d(14rpx, 120rpx, 0);
    opacity: 0;
  }
}

@keyframes scene-enter-zoom {
  0% {
    transform: scale(1.045);
    filter: saturate(0.84) blur(3.4rpx);
  }
  100% {
    transform: scale(1);
    filter: saturate(1) blur(0);
  }
}

@keyframes scene-curtain-fade {
  0% {
    opacity: 0.72;
  }
  100% {
    opacity: 0;
  }
}

@keyframes ambient-time-breathe {
  0%,
  100% {
    opacity: 0.48;
    transform: scale(1);
  }
  50% {
    opacity: 0.62;
    transform: scale(1.015);
  }
}

.rain-drop {
  position: absolute;
  top: -16vh;
  width: 2rpx;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0), rgba(212, 231, 255, 0.85));
  border-radius: 999rpx;
  animation-name: rain-fall;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
  will-change: transform, opacity;
}

@keyframes rain-fall {
  0% {
    transform: translate3d(0, -8vh, 0);
    opacity: 0;
  }

  12% {
    opacity: 1;
  }

  100% {
    transform: translate3d(-12rpx, 115vh, 0);
    opacity: 0;
  }
}

/* 页面容器 */
.page-swiper {
  flex: 1;
  width: 100%;
  min-height: 0;
  position: relative;
  height: 100%;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
  position: relative;
}

/* 顶部自定义 Tab (Custom Header) */
.tab-container {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  height: 100rpx;
  padding: 0 24rpx;
  position: relative;
  z-index: 10;
  transition:
    background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.tab-item {
  position: relative;
  padding: 12rpx 28rpx;
  margin: 0 8rpx;
  font-size: 24rpx;
  color: #999;
  transition:
    color 0.3s cubic-bezier(0.22, 1, 0.36, 1),
    transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.tab-item.active {
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #333;
  border-radius: 2rpx;
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

/* 白噪音控制 */
.audio-control {
  margin: 16rpx 20rpx 8rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  transition:
    background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 0.45s cubic-bezier(0.22, 1, 0.36, 1),
    transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
}

.audio-control.collapsed {
  padding: 14rpx 18rpx;
  transform: translateY(-1rpx);
}

.audio-control.writing-quiet {
  opacity: 0.9;
}

.audio-control.writing-focused {
  opacity: 0.76;
}

.audio-control.writing-focused .ambient-control-title,
.audio-control.writing-focused .ambient-control-summary {
  color: #9ca3af;
}

.audio-control.writing-focused .ambient-control-toggle {
  background: rgba(148, 163, 184, 0.12);
  color: #64748b;
}

.ambient-control-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.ambient-control-meta {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
}

.ambient-control-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
}

.ambient-control-summary {
  font-size: 19rpx;
  color: #9ca3af;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 62vw;
}

.ambient-control-toggle {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #6366f1;
  background: rgba(99, 102, 241, 0.1);
}

.ambient-control-body {
  margin-top: 12rpx;
}

.audio-main {
  display: flex;
  align-items: center;
}

.audio-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.audio-btn-icon {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.audio-meta {
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: 2rpx;
}

.audio-title {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
}

.audio-status {
  font-size: 20rpx;
  color: #8f8f98;
}

.audio-expand {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background-color: rgba(0, 0, 0, 0.06);
}

.audio-expand-icon {
  font-size: 20rpx;
  color: #666;
}

.audio-volume-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.audio-volume-label,
.audio-volume-value {
  font-size: 20rpx;
  color: #666;
}

.audio-slider {
  flex: 1;
}

.rain-mode-row {
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(15, 23, 42, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.rain-mode-meta {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.rain-mode-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #374151;
}

.rain-mode-desc {
  font-size: 18rpx;
  color: #9ca3af;
}

.scene-mode-row {
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(15, 23, 42, 0.08);
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.scene-mode-meta {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.scene-mode-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #374151;
}

.scene-mode-desc {
  font-size: 18rpx;
  color: #6b7280;
}

.scene-mode-sound {
  font-size: 17rpx;
  color: #94a3b8;
}

.scene-type-scroll {
  margin-top: 10rpx;
  white-space: nowrap;
}

.scene-intensity-row {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.scene-intensity-label,
.scene-intensity-value {
  font-size: 20rpx;
  color: #64748b;
}

.scene-intensity-slider {
  flex: 1;
}

.scene-type-row {
  display: inline-flex;
  gap: 10rpx;
  padding-bottom: 4rpx;
}

.scene-type-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.06);
  color: #6b7280;
  transition: all 0.2s ease;
}

.scene-type-chip.active {
  background: rgba(56, 189, 248, 0.18);
  color: #0f766e;
}

.scene-type-chip-icon {
  font-size: 20rpx;
}

.scene-type-chip-label {
  font-size: 20rpx;
}

.container.rain-perf-low .rain-drop {
  width: 1.5rpx;
  filter: saturate(0.88);
}

/* 内容区域 (Feed List) */
.content-swiper {
  flex: 1;
  width: 100%;
  min-height: 0;
}

.writing-workspace {
  flex: 1;
  height: 100%;
  min-height: 0;
  position: relative;
  display: flex;
  padding: 14rpx 12rpx 20rpx;
  box-sizing: border-box;
}

.writing-left-rail {
  position: fixed;
  left: 22rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 88rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  z-index: 35;
}

.writing-workspace.writing-focused .writing-left-rail,
.writing-workspace.writing-focused .writing-right-rail {
  opacity: 0.46;
  transform: translateY(-50%) scale(0.96);
}

.writing-workspace.writing-focused .left-entry-card {
  animation-play-state: paused;
  filter: saturate(0.76);
}

.writing-workspace.writing-focused .companion-nest-card {
  opacity: 0.92;
}

.left-entry-card {
  border-radius: 18rpx;
  min-height: 82rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  box-shadow: none;
  animation: side-entry-breathe 3.2s ease-in-out infinite;
  transition: transform 0.22s ease, filter 0.22s ease;
}

.left-entry-card.is-active {
  transform: translateY(-2rpx) scale(1.04);
  filter: saturate(1.08);
}

.companion-nest-card {
  min-height: 94rpx;
  gap: 6rpx;
  padding: 8rpx 4rpx;
  box-sizing: border-box;
  background: linear-gradient(165deg, rgba(245, 158, 11, 0.16), rgba(251, 191, 36, 0.08));
  border: 1rpx solid rgba(245, 158, 11, 0.22);
  box-shadow: 0 8rpx 18rpx rgba(217, 119, 6, 0.14);
}

.companion-nest-card.is-highlighted {
  border-color: rgba(99, 102, 241, 0.5);
  box-shadow: 0 0 0 4rpx rgba(99, 102, 241, 0.14), 0 10rpx 22rpx rgba(79, 70, 229, 0.2);
}

.companion-nest-shell {
  width: 58rpx;
  height: 58rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at 30% 24%, rgba(255, 255, 255, 0.94), rgba(254, 243, 199, 0.84));
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.44);
}

.companion-nest-resting-sprite {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  position: relative;
  animation: companion-resting-breathe 3.8s ease-in-out infinite;
}

.companion-nest-resting-sprite.cloud {
  background: radial-gradient(circle at 30% 26%, rgba(255, 255, 255, 0.96), rgba(191, 219, 254, 0.88));
}

.companion-nest-resting-sprite.core {
  background: radial-gradient(circle at 30% 30%, rgba(224, 231, 255, 0.95), rgba(99, 102, 241, 0.9));
}

.companion-nest-resting-sprite .companion-eye {
  top: 16rpx;
  width: 4rpx;
  height: 6rpx;
}

.companion-nest-resting-sprite .companion-eye.left {
  left: 13rpx;
}

.companion-nest-resting-sprite .companion-eye.right {
  right: 13rpx;
}

.companion-nest-emoji {
  font-size: 32rpx;
  line-height: 1;
}

.companion-nest-label {
  font-size: 16rpx;
  line-height: 1.25;
  color: #92400e;
  text-align: center;
}

.left-entry-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  line-height: 1;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  backdrop-filter: blur(8rpx) saturate(1.08);
  -webkit-backdrop-filter: blur(8rpx) saturate(1.08);
  box-shadow:
    0 8rpx 18rpx rgba(15, 23, 42, 0.18),
    0 0 16rpx rgba(129, 140, 248, 0.2);
  transition: box-shadow 0.22s ease, transform 0.22s ease;
}

.writing-workspace.theme-male .left-entry-icon {
  background: rgba(15, 23, 42, 0.2);
  border-color: rgba(148, 163, 184, 0.4);
  box-shadow:
    0 8rpx 18rpx rgba(15, 23, 42, 0.3),
    0 0 16rpx rgba(96, 165, 250, 0.24);
}

.writing-workspace.theme-male .left-entry-card.is-active .left-entry-icon {
  box-shadow:
    0 10rpx 22rpx rgba(15, 23, 42, 0.34),
    0 0 22rpx rgba(56, 189, 248, 0.34);
}

.left-entry-card.is-active .left-entry-icon {
  transform: scale(1.06);
  box-shadow:
    0 10rpx 22rpx rgba(15, 23, 42, 0.22),
    0 0 22rpx rgba(129, 140, 248, 0.3);
}

.blind-box-icon.shake {
  animation: blindbox-entry-shake 1.2s ease-in-out;
}

.writing-left-rail .left-entry-card:nth-child(2) {
  animation-delay: 0.3s;
}

.writing-right-rail .left-entry-card:nth-child(2) {
  animation-delay: 0.2s;
}

.writing-right-rail .left-entry-card:nth-child(3) {
  animation-delay: 0.4s;
}

.writing-right-rail .left-entry-card:nth-child(4) {
  animation-delay: 0.6s;
}

.writing-right-rail .left-entry-card:nth-child(5) {
  animation-delay: 0.8s;
}

.writing-right-rail .left-entry-card:nth-child(6) {
  animation-delay: 1s;
}

.writing-right-rail .left-entry-card:nth-child(7) {
  animation-delay: 1.2s;
}

.left-entry-title {
  font-size: 20rpx;
  font-weight: 600;
  color: #334155;
}

.left-entry-desc {
  max-width: 100%;
  font-size: 16rpx;
  color: #64748b;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.left-tool-title {
  font-size: 20rpx;
  font-weight: 600;
  color: #334155;
  margin-bottom: 6rpx;
  display: block;
}

.theme-tabs.compact {
  margin-bottom: 8rpx;
}

.theme-tabs.compact .theme-tab {
  font-size: 18rpx;
  padding: 6rpx 0;
}

.theme-list.compact {
  margin: -4rpx;
}

.theme-item.compact {
  width: calc(50% - 8rpx);
  margin: 4rpx;
  padding: 3rpx 4rpx;
}

.theme-item.compact .theme-color {
  width: 100%;
  height: 60rpx;
  margin-bottom: 2rpx;
  border-radius: 8rpx;
}

.theme-item.compact .theme-name {
  font-size: 14rpx;
  line-height: 1.2;
  text-align: center;
}

.left-tool-card.audio-control {
  margin: 0;
  padding: 10rpx;
  border-radius: 14rpx;
}

.left-tool-card .ambient-control-title {
  font-size: 20rpx;
}

.left-tool-card .ambient-control-summary {
  max-width: 104rpx;
  font-size: 16rpx;
}

.audio-main.compact {
  margin-top: 6rpx;
}

.audio-volume-row.compact {
  gap: 8rpx;
}

.rain-mode-row.compact,
.scene-mode-row.compact {
  margin-top: 10rpx;
  padding-top: 8rpx;
}

