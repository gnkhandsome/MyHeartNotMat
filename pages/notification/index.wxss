.container {
  min-height: 100vh;
  padding-top: 88rpx;
}

/* 导航栏 */
.navigation-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  z-index: 100;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.nav-left {
  width: 80rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
}

.nav-back-icon {
  font-size: 48rpx;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
}

.nav-right {
  width: 200rpx;
  display: flex;
  justify-content: flex-end;
  gap: 32rpx;
}

.nav-action {
  font-size: 28rpx;
  padding: 8rpx 16rpx;
}

/* 通知列表 */
.notification-list {
  height: calc(100vh - 88rpx);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  gap: 24rpx;
}

.empty-icon {
  font-size: 128rpx;
}

.empty-text {
  font-size: 32rpx;
}

/* 通知项 */
.notification-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  gap: 24rpx;
}

.notification-item.read {
  opacity: 0.7;
}

.notification-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.notification-type-icon {
  font-size: 40rpx;
}

.notification-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.notification-sender {
  font-size: 32rpx;
  font-weight: 600;
}

.notification-text {
  font-size: 28rpx;
  line-height: 1.5;
}

.notification-time {
  font-size: 24rpx;
}

.notification-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16rpx;
}

.notification-unread-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #ff4757;
}

.notification-delete {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
}
