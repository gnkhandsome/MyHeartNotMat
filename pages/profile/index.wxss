.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 120rpx;
}

.user-info-section {
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 24rpx;
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #6366f1, #6366f1cc);
}

.avatar-text {
  font-size: 80rpx;
  color: #fff;
  font-weight: 600;
}

.avatar-edit-btn {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #6366f1;
  border: 4rpx solid #fff;
}

.edit-icon {
  font-size: 28rpx;
}

.user-details {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.notification-btn {
  position: absolute;
  top: 40rpx;
  right: 32rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid rgba(148, 163, 184, 0.2);
}

.notification-icon {
  font-size: 36rpx;
}

.notification-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.notification-count {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
}

.mood {
  font-size: 26rpx;
}

.tabs-section {
  padding: 0 32rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.12);
}

.tabs {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.tab {
  padding: 24rpx 16rpx;
  position: relative;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #6366f1;
  border-radius: 2rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 500;
}

.content-section {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.content-list {
  flex: 1;
  height: 0;
  padding: 24rpx 20rpx;
  box-sizing: border-box;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.empty-action-btn {
  padding: 24rpx 80rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
}

.empty-action-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.post-card {
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.post-card-header {
  margin-bottom: 16rpx;
}

.post-user-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.user-avatar-small {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.user-avatar-text-small {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.user-nickname-small {
  font-size: 26rpx;
  font-weight: 500;
}

.post-card-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 16rpx;
  padding-left: 12rpx;
  margin-left: 68rpx;
  position: relative;
}

.title-bar {
  position: absolute;
  left: 0;
  top: 8rpx;
  bottom: 8rpx;
  width: 6rpx;
  border-radius: 3rpx;
  background-color: #6366f1;
}

.post-card-content {
  font-size: 30rpx;
  line-height: 1.7;
  margin-bottom: 16rpx;
  margin-left: 68rpx;
}

.post-card-meta {
  font-size: 24rpx;
  margin-bottom: 12rpx;
  margin-left: 68rpx;
}

.post-card-quote {
  font-size: 26rpx;
  font-style: italic;
  text-align: center;
  padding: 16rpx 0;
  margin-bottom: 12rpx;
  margin-left: 68rpx;
}

.post-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.post-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.post-delete {
  font-size: 24rpx;
  color: #ef4444;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.post-stats {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.stat-item {
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.post-time {
  font-size: 24rpx;
}

.custom-tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-sizing: border-box;
  border-top: 1rpx solid rgba(148, 163, 184, 0.12);
  z-index: 100;
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  gap: 4rpx;
}

.tabbar-icon {
  font-size: 40rpx;
}

.tabbar-text {
  font-size: 20rpx;
}

.tabbar-item.active .tabbar-text {
  font-weight: 600;
}
