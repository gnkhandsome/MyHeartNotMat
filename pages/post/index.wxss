.container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
  position: relative;
  box-sizing: border-box;
  transition: background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.shred-canvas {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
  z-index: 9999;
}

/* 写作沉浸头部 */
.writing-ambient-panel {
  margin-bottom: 16rpx;
  padding: 24rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(130deg, rgba(255, 250, 240, 0.82), rgba(250, 245, 255, 0.74));
  border: 1rpx solid rgba(251, 191, 36, 0.16);
  box-shadow: 0 10rpx 22rpx rgba(148, 163, 184, 0.13);
}

.writing-ambient-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #854d0e;
}

.writing-ambient-subtitle {
  margin-top: 8rpx;
  display: block;
  font-size: 21rpx;
  line-height: 1.62;
  color: #78716c;
}

/* 沉浸式输入区域 */
.input-container {
  padding: 30rpx 26rpx;
  min-height: 380rpx;
  border-radius: 28rpx;
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.52);
}

.post-type-scroll {
  white-space: nowrap;
  margin: 8rpx 0 0;
}

.post-type-row {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 8rpx;
}

.post-type-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.06);
  color: #6b7280;
  transition: all 0.25s ease;
}

.post-type-chip.active {
  background: rgba(99, 102, 241, 0.16);
  color: #3730a3;
  box-shadow: 0 6rpx 14rpx rgba(99, 102, 241, 0.16);
}

.post-type-chip-icon {
  font-size: 22rpx;
}

.post-type-chip-label {
  font-size: 22rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  min-height: 300rpx;
  font-size: 30rpx;
  line-height: 1.72;
  border: none;
  outline: none;
  resize: none;
  background: transparent;
}

.input-letter {
  line-height: 1.82;
}

.input-postcard {
  letter-spacing: 1rpx;
}

.input-diary {
  line-height: 1.72;
}

.input-vlog {
  line-height: 1.64;
}

.immersive-form-panel {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.immersive-form-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.immersive-input,
.immersive-script-input {
  width: 100%;
  border-radius: 14rpx;
  background: rgba(15, 23, 42, 0.04);
  border: 1rpx solid rgba(148, 163, 184, 0.25);
  color: #374151;
  font-size: 22rpx;
  padding: 12rpx 14rpx;
  box-sizing: border-box;
}

.immersive-script-input {
  min-height: 148rpx;
  line-height: 1.6;
}

.mood-score-row {
  border-radius: 14rpx;
  background: rgba(16, 185, 129, 0.08);
  padding: 10rpx 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.mood-score-row slider {
  flex: 1;
}

.mood-score-label,
.mood-score-value {
  font-size: 20rpx;
  color: #065f46;
}

/* 功能入口 */
.action-buttons {
  margin-top: 18rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 18rpx 16rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  transition:
    background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 0.45s cubic-bezier(0.22, 1, 0.36, 1),
    transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
}

.action-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  min-width: 208rpx;
  padding: 12rpx 14rpx;
  border-radius: 16rpx;
  transition:
    transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
    background-color 0.28s cubic-bezier(0.22, 1, 0.36, 1);
}

.action-button.publish-btn {
  background: linear-gradient(148deg, rgba(129, 140, 248, 0.26), rgba(99, 102, 241, 0.2));
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.5);
}

.action-button.publish-btn .action-text {
  color: #3730a3;
  font-weight: 600;
}

.action-button.secondary-btn {
  opacity: 0.84;
  background: rgba(148, 163, 184, 0.08);
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 24rpx;
  color: #7f7f88;
}

.package-flow-tip {
  margin-top: 10rpx;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  font-size: 20rpx;
  line-height: 1.55;
  color: #6b7280;
  background: rgba(255, 255, 255, 0.46);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}

.list-section {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #333;
}

.my-publish-tabs {
  margin-bottom: 14rpx;
  display: flex;
  gap: 12rpx;
}

.my-publish-tab {
  min-width: 120rpx;
  text-align: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #64748b;
  background: rgba(148, 163, 184, 0.16);
}

.my-publish-tab.active {
  color: #fff;
  background: linear-gradient(135deg, #6366f1, #4f46e5);
  box-shadow: 0 8rpx 18rpx rgba(99, 102, 241, 0.24);
}

.record-card {
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.45);
  margin-bottom: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.48);
  transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.32s ease;
}

.record-type-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.record-type-pill {
  font-size: 20rpx;
  color: #4b5563;
  background: rgba(255, 255, 255, 0.76);
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.record-vlog-duration {
  font-size: 20rpx;
  color: #6b7280;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.08);
}

.record-card.type-letter {
  border-left: 8rpx solid rgba(244, 114, 182, 0.55);
}

.record-card.type-postcard {
  border-left: 8rpx solid rgba(56, 189, 248, 0.55);
}

.record-card.type-diary {
  border-left: 8rpx solid rgba(34, 197, 94, 0.42);
}

.record-card.type-vlog {
  border-left: 8rpx solid rgba(99, 102, 241, 0.5);
}

.record-content {
  font-size: 27rpx;
  line-height: 1.68;
}

.record-immersive-meta {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.record-meta-pill {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  color: #475569;
  background: rgba(255, 255, 255, 0.66);
}

.record-letter-salutation {
  font-size: 22rpx;
  color: #be185d;
}

.record-letter-signature {
  font-size: 22rpx;
  color: #64748b;
}

.record-immersive-meta.vlog-shots {
  flex-direction: column;
  gap: 6rpx;
}

.record-shot-line {
  font-size: 20rpx;
  color: #475569;
  line-height: 1.45;
}

.record-footer {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-time {
  font-size: 20rpx;
  color: #8f8f98;
}

.card-shatter-btn {
  padding: 8rpx 18rpx;
  font-size: 20rpx;
  line-height: 1;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(135deg, #ff8a7a, #ff5c7a);
  box-shadow: 0 8rpx 20rpx rgba(255, 92, 122, 0.28);
}

.card-private-btn {
  padding: 8rpx 18rpx;
  font-size: 20rpx;
  line-height: 1;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(135deg, #6366f1, #4f46e5);
  box-shadow: 0 8rpx 20rpx rgba(99, 102, 241, 0.26);
}

.record-card.shattering {
  pointer-events: none;
  transform-origin: center center;
  animation: card-shatter 0.36s ease-out forwards;
}

.empty {
  color: #9ca3af;
  font-size: 22rpx;
  padding: 8rpx 4rpx 16rpx;
}

.input-container.post-shattering .input {
  animation: post-input-shake 0.28s ease-in-out 2;
  opacity: 0.65;
}

/* 粒子动画容器 */
.particle-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 1000;
}

.particle {
  position: absolute;
}

/* 粒子动画 */
@keyframes petal-fall {
  0% {
    transform: translateY(0) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(100vh) rotate(360deg);
    opacity: 0;
  }
}

@keyframes shatter {
  0% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: scale(0.1) rotate(180deg);
    opacity: 0;
  }
}

@keyframes card-shatter {
  0% {
    opacity: 1;
    transform: scale(1) rotate(0deg);
    filter: blur(0);
  }
  55% {
    opacity: 0.72;
    transform: scale(1.03) rotate(-1.2deg);
    filter: blur(1.6rpx);
  }
  100% {
    opacity: 0;
    transform: scale(0.82) translateY(-10rpx) rotate(4deg);
    filter: blur(6rpx);
  }
}

@keyframes post-input-shake {
  0% { transform: translateX(0); }
  25% { transform: translateX(-8rpx); }
  50% { transform: translateX(6rpx); }
  75% { transform: translateX(-4rpx); }
  100% { transform: translateX(0); }
}

/* 响应式设计 */
@media (max-width: 375px) {
  .writing-ambient-panel {
    padding: 18rpx 18rpx;
  }
  
  .input-container {
    padding: 24rpx 20rpx;
  }
  
  .input {
    font-size: 28rpx;
  }
  
  .action-icon {
    font-size: 32rpx;
  }
  
  .action-text {
    font-size: 20rpx;
  }
}