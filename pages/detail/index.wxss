.container {
  min-height: 100vh;
  position: relative;
  background-image: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
}

.detail-scroll {
  height: 100vh;
  padding: 18rpx 20rpx calc(42rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  position: relative;
  z-index: 2;
}

.scene-head,
.detail-card,
.comment-section {
  border-radius: 24rpx;
  padding: 24rpx 22rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.48);
}

.owner-toolbar {
  border-radius: 24rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.48);
}

.owner-toolbar-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.owner-toolbar-title {
  font-size: 25rpx;
  font-weight: 600;
}

.owner-toolbar-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.owner-toolbar-btn {
  font-size: 21rpx;
}

.owner-toolbar-btn.primary {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #fff;
  background: #6366f1;
}

.owner-scene-panel {
  margin-top: 14rpx;
}

.owner-scene-label {
  display: block;
  font-size: 20rpx;
}

.owner-scene-chip-group {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.owner-scene-chip {
  font-size: 20rpx;
  line-height: 1;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #64748b;
  background: rgba(148, 163, 184, 0.16);
}

.owner-scene-chip.active {
  color: #fff;
  background: #6366f1;
}

.owner-scene-intensity-row {
  margin-top: 12rpx;
}

.scene-head {
  backdrop-filter: blur(4rpx);
  -webkit-backdrop-filter: blur(4rpx);
}

.scene-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
}

.scene-desc {
  margin-top: 8rpx;
  display: block;
  font-size: 21rpx;
  line-height: 1.62;
}

.detail-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.detail-type-pill {
  font-size: 19rpx;
  border-radius: 999rpx;
  padding: 7rpx 14rpx;
  background: rgba(255, 255, 255, 0.72);
}

.detail-time {
  font-size: 19rpx;
}

.detail-content {
  display: block;
  font-size: 30rpx;
  line-height: 1.74;
}

.detail-content-input {
  width: 100%;
  min-height: 180rpx;
  font-size: 29rpx;
  line-height: 1.74;
}

.detail-meta-group {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.detail-meta {
  font-size: 22rpx;
}

.detail-meta-input {
  width: 100%;
  min-height: 64rpx;
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #334155;
  background: rgba(148, 163, 184, 0.12);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  box-sizing: border-box;
}

.letter-edit-group {
  flex-direction: column;
}

.detail-meta-pill {
  font-size: 19rpx;
  border-radius: 999rpx;
  padding: 6rpx 12rpx;
  background: rgba(255, 255, 255, 0.66);
}

.vlog-shot-list {
  flex-direction: column;
  gap: 6rpx;
}

.detail-shot-line {
  font-size: 20rpx;
  line-height: 1.45;
}

.comment-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.comment-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.18);
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.comment-user {
  font-size: 22rpx;
  font-weight: 600;
}

.comment-time {
  font-size: 18rpx;
}

.comment-content {
  font-size: 21rpx;
  line-height: 1.62;
}

.rain-overlay {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  overflow: hidden;
}

.rain-drop {
  position: absolute;
  top: -16vh;
  width: 2rpx;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0), rgba(212, 231, 255, 0.85));
  border-radius: 999rpx;
  animation-name: rain-fall;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
}

.immersive-scene-overlay {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.scene-particle {
  position: absolute;
  border-radius: 999rpx;
  animation-name: scene-float;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
}

.scene-particle.kind-sun {
  background: radial-gradient(circle, rgba(254, 240, 138, 0.95), rgba(250, 204, 21, 0.3));
}

.scene-particle.kind-cloud {
  background: radial-gradient(circle, rgba(241, 245, 249, 0.9), rgba(203, 213, 225, 0.34));
}

.scene-particle.kind-rain {
  width: 2rpx !important;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0), rgba(191, 219, 254, 0.85));
}

.scene-particle.kind-wind {
  background: linear-gradient(90deg, rgba(187, 247, 208, 0), rgba(134, 239, 172, 0.68), rgba(187, 247, 208, 0));
}

.scene-particle.kind-snow {
  background: radial-gradient(circle, rgba(255, 255, 255, 0.96), rgba(219, 234, 254, 0.5));
}

.scene-particle.kind-leaf {
  background: radial-gradient(circle at 30% 30%, rgba(187, 247, 208, 0.92), rgba(110, 231, 183, 0.5));
}

@keyframes scene-float {
  0% {
    transform: translate3d(0, -8rpx, 0);
    opacity: 0;
  }
  15% {
    opacity: 1;
  }
  100% {
    transform: translate3d(14rpx, 120rpx, 0);
    opacity: 0;
  }
}

@keyframes rain-fall {
  0% {
    transform: translate3d(0, -8vh, 0);
    opacity: 0;
  }
  12% {
    opacity: 1;
  }
  100% {
    transform: translate3d(-12rpx, 115vh, 0);
    opacity: 0;
  }
}