}

.content-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.content-item:last-child {
  border-bottom: none;
}

.content-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.content-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.content-arrow {
  font-size: 32rpx;
  color: #999;
}

.blind-box {
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 24rpx;
  transition:
    background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.blind-box-content {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
  cursor: pointer;
}

.blind-box-card {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  perspective: 1000rpx;
}

.blind-box-front,
.blind-box-back {
  width: 100%;
  height: 100%;
  position: absolute;
  backface-visibility: hidden;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-radius: 20rpx;
  transition: transform 0.6s;
}

.blind-box-front {
  border-radius: 20rpx;
  transition: transform 0.6s;
}

.blind-box-back {
  transform: rotateY(180deg);
  padding: 20rpx;
  text-align: center;
  border-radius: 20rpx;
  transition: transform 0.6s;
}

.blind-box-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.blind-box-text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.blind-box-quote {
  font-size: 24rpx;
  line-height: 1.5;
  color: white;
}

.blind-box-card.flipping .blind-box-front {
  transform: rotateY(180deg);
}

.blind-box-card.flipping .blind-box-back {
  transform: rotateY(0deg);
}

.theme-setting {
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 24rpx;
  transition:
    background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.theme-tabs {
  display: flex;
  margin-bottom: 12rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.theme-tab {
  flex: 1;
  padding: 10rpx;
  text-align: center;
  font-size: 20rpx;
  transition:
    color 0.3s cubic-bezier(0.22, 1, 0.36, 1),
    background-color 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.theme-list {
  display: flex;
  flex-wrap: wrap;
  margin: -6rpx;
}

.theme-item {
  width: calc(33.33% - 12rpx);
  margin: 6rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx;
  transition:
    transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
    background-color 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.theme-item:hover {
  transform: translateY(-5rpx);
}

.theme-color {
  width: 100%;
  height: 60rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 0;
}

.theme-name {
  font-size: 14rpx;
  color: #fff;
  font-weight: 500;
}

/* 自定义底部导航栏 */
.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 104rpx;
  padding: 10rpx 20rpx calc(env(safe-area-inset-bottom) + 10rpx) 20rpx;
  z-index: 10;
  background: transparent;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  border-top: none;
}

.fab-movable-area {
  position: fixed;
  inset: 0;
  z-index: 30;
  width: 100vw;
  height: 100vh;
  pointer-events: auto;
}

.fab-movable-view {
  width: 72rpx;
  height: 72rpx;
  pointer-events: auto;
  position: absolute;
}

.companion-trail-layer {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 25;
}

.companion-trail-dot {
  position: absolute;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.92), rgba(147, 197, 253, 0.72));
  box-shadow: 0 0 12rpx rgba(125, 211, 252, 0.35);
  animation: companion-trail-fade 0.32s ease-out forwards;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  box-sizing: border-box;
  width: calc(100% / 3);
  max-width: 120rpx;
}

.tabbar-item.active {
  font-weight: bold;
}

.tabbar-icon {
  font-size: 28rpx;
  display: block;
  margin-bottom: 2rpx;
  line-height: 1;
}

.tabbar-text {
  font-size: 20rpx;
  color: #64748b;
  line-height: 1;
}

.tabbar-item.active .tabbar-text {
  font-weight: bold;
}

/* 呼吸岛屿启动界面 */
.breathing-start-overlay {
  position: fixed;
  inset: 0;
  z-index: 2000;
  background: rgba(15, 23, 42, 0.92);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.breathing-start-container {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
  padding: 80rpx 60rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  box-shadow: 
    0 20rpx 48rpx rgba(15, 23, 42, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.12);
}

.breathing-island-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.breathing-start-button-container {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.breathing-start-progress-circle {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  overflow: visible;
}

.breathing-start-progress {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 6rpx solid transparent;
  border-top-color: #818cf8;
  border-right-color: #818cf8;
  transform-origin: center;
  transition: transform 0.1s ease;
}

.breathing-start-button {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(129, 140, 248, 0.2);
  border: 2rpx solid rgba(129, 140, 248, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  transition: all 0.3s ease;
}

.breathing-start-button:active {
  transform: scale(0.95);
}

.breathing-start-icon {
  font-size: 64rpx;
  z-index: 1;
}

/* 呼吸岛屿沉浸式引导 */
.breathing-island-overlay {
  position: fixed;
  inset: 0;
  z-index: 2000;
  background: rgba(15, 23, 42, 0.92);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.breathing-island-timer-fixed {
  position: fixed;
  top: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 72rpx;
  font-weight: 700;
  color: #818cf8;
  text-shadow: 0 8rpx 24rpx rgba(129, 140, 248, 0.6);
  z-index: 2001;
}

.breathing-island-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.breathing-island-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  padding: 60rpx 60rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  box-shadow: 
    0 20rpx 48rpx rgba(15, 23, 42, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.12);
  width: 80vw;
  max-width: 600rpx;
  min-height: 400rpx;
}

.breathing-island-phase-timer-container {
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.breathing-island-close {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
  cursor: pointer;
  z-index: 10;
  transition: color 0.3s ease;
}

.breathing-island-close:active {
  color: rgba(255, 255, 255, 1);
}

.breathing-island-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 4rpx 16rpx rgba(129, 140, 248, 0.4);
}

.breathing-island-round {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.breathing-island-phase {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 4rpx 16rpx rgba(129, 140, 248, 0.4);
  animation: breathing-phase-pulse 4s ease-in-out infinite;
}

.breathing-island-phase-timer {
  font-size: 64rpx;
  font-weight: 700;
  color: #818cf8;
  text-shadow: 0 8rpx 24rpx rgba(129, 140, 248, 0.6);
  animation: breathing-phase-timer-pulse 1s ease-in-out infinite;
}

.breathing-island-timer {
  font-size: 72rpx;
  font-weight: 700;
  color: #818cf8;
  text-shadow: 0 8rpx 24rpx rgba(129, 140, 248, 0.6);
}

@keyframes breathing-phase-timer-pulse {
  0%, 100% {
    opacity: 0.8;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.1);
  }
}

.breathing-island-tip {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

@keyframes breathing-phase-pulse {
  0%, 100% {
    opacity: 0.8;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
}

.companion-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.companion-sprite {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(59, 130, 246, 0.2);
  animation: companion-float 2.8s ease-in-out infinite;
  transition: none;
}

.companion-sprite.dragging {
  animation: none;
  transition: none;
}

.companion-sprite.tap-feedback {
  animation: companion-tap-feedback 0.22s ease-out;
}

.companion-sprite.cloud {
  background: radial-gradient(circle at 30% 26%, rgba(255, 255, 255, 0.96), rgba(191, 219, 254, 0.88));
}

.companion-sprite.core {
  background: radial-gradient(circle at 30% 30%, rgba(224, 231, 255, 0.95), rgba(99, 102, 241, 0.9));
}

.companion-eye {
  position: absolute;
  top: 24rpx;
  width: 6rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.75);
}

.companion-eye.left {
  left: 20rpx;
}

.companion-eye.right {
  right: 20rpx;
}

.companion-sprite.state-happy {
  filter: brightness(1.08) saturate(1.08);
  animation-duration: 2s;
}

.companion-sprite.state-sad {
  filter: grayscale(0.16) brightness(0.92);
  transform: scale(0.92);
}

.companion-sprite.state-breathing {
  animation: companion-breathing 3s ease-in-out infinite;
}

.companion-sprite.drag-level-1 {
  transform: scaleX(1.04) scaleY(0.97);
}

.companion-sprite.drag-level-2 {
  transform: scaleX(1.1) scaleY(0.92);
}

.companion-sprite.drag-level-3 {
  transform: scaleX(1.16) scaleY(0.86);
}

.companion-sprite.is-shy {
  transform: translateX(-8rpx) scale(0.94);
}

.companion-sprite.is-shy.drag-level-1 {
  transform: translateX(-8rpx) scaleX(1.02) scaleY(0.92);
}

.companion-sprite.is-shy.drag-level-2 {
  transform: translateX(-8rpx) scaleX(1.08) scaleY(0.88);
}

.companion-sprite.is-shy.drag-level-3 {
  transform: translateX(-8rpx) scaleX(1.14) scaleY(0.82);
}

.companion-sprite.selected {
  box-shadow: 
    0 0 0 6rpx rgba(99, 102, 241, 0.3),
    0 0 24rpx rgba(99, 102, 241, 0.6),
    0 10rpx 26rpx rgba(59, 130, 246, 0.2);
  animation: companion-selected-pulse 1.2s ease-in-out infinite;
}

@keyframes companion-selected-pulse {
  0%, 100% {
    box-shadow: 
      0 0 0 6rpx rgba(99, 102, 241, 0.3),
      0 0 24rpx rgba(99, 102, 241, 0.6),
      0 10rpx 26rpx rgba(59, 130, 246, 0.2);
  }
  50% {
    box-shadow: 
      0 0 0 8rpx rgba(99, 102, 241, 0.4),
      0 0 32rpx rgba(99, 102, 241, 0.8),
      0 12rpx 30rpx rgba(59, 130, 246, 0.25);
  }
}

.companion-bubble {
  position: absolute;
  right: 52rpx;
  top: -8rpx;
  min-width: 180rpx;
  max-width: 320rpx;
  padding: 10rpx 14rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  line-height: 1.4;
  animation: companion-bubble-in 0.2s ease-out;
}

.companion-bubble.side-right {
  right: 52rpx;
  left: auto;
}

.companion-bubble.side-right::after {
  right: -8rpx;
  left: auto;
  border-right: none;
  border-left: 10rpx solid rgba(255, 255, 255, 0.96);
}

.companion-bubble.side-left {
  left: 52rpx;
  right: auto;
}

.companion-bubble.side-left::after {
  left: -8rpx;
  right: auto;
  border-left: none;
  border-right: 10rpx solid rgba(255, 255, 255, 0.96);
}

.companion-bubble.vertical-top {
  top: -4rpx;
}

.companion-bubble.vertical-middle {
  top: -8rpx;
}

.companion-bubble.vertical-bottom {
  top: auto;
  bottom: -4rpx;
}

.companion-bubble.vertical-bottom::after {
  top: auto;
  bottom: 16rpx;
}

.companion-bubble::after {
  content: '';
  position: absolute;
  right: -8rpx;
  top: 16rpx;
  width: 0;
  height: 0;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  border-left: 10rpx solid rgba(255, 255, 255, 0.96);
}

@keyframes companion-float {
  0%,
  100% { margin-top: 0; }
  50% { margin-top: -6rpx; }
}

@keyframes companion-breathing {
  0%,
  100% { transform: scale(1); filter: brightness(1); }
  50% { transform: scale(1.18); filter: brightness(1.08); }
}

@keyframes companion-resting-breathe {
  0%,
  100% {
    transform: scale(0.96);
    box-shadow: 0 4rpx 10rpx rgba(59, 130, 246, 0.18);
  }
  50% {
    transform: scale(1);
    box-shadow: 0 8rpx 14rpx rgba(59, 130, 246, 0.24);
  }
}

@keyframes companion-bubble-in {
  from {
    opacity: 0;
    transform: translateY(6rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes companion-tap-feedback {
  0% {
    transform: scale(1);
    filter: brightness(1);
  }
  45% {
    transform: scale(1.12);
    filter: brightness(1.12) saturate(1.08);
  }
  100% {
    transform: scale(1);
    filter: brightness(1);
  }
}

@keyframes companion-trail-fade {
  0% {
    opacity: 0.75;
    transform: translate(-50%, -50%) scale(1);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.4);
  }
}

