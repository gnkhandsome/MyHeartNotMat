.hanging-tassels {
  margin-top: 8rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 5rpx;
}

.ornament-tassel-strand {
  width: 3rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0.98), rgba(254, 240, 138, 0.84));
  transform-origin: top center;
  animation: tassel-swing 1.8s ease-in-out infinite;
}

.ornament-tassel-strand.left {
  animation-delay: 0s;
}

.ornament-tassel-strand.center {
  height: 26rpx;
  animation-delay: 0.16s;
}

.ornament-tassel-strand.right {
  animation-delay: 0.32s;
}

.hanging-ornament-label {
  margin-top: 6rpx;
  font-size: 16rpx;
  color: #64748b;
  transform: scale(0.95);
}

.ornament-drag-layer {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 120;
}

.ornament-drag-ghost {
  position: fixed;
  width: 68px;
  height: 68px;
  border-radius: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12px 28px rgba(15, 23, 42, 0.24);
  transform: scale(1.04);
}

.ornament-drag-ghost.ornament-knot {
  background: linear-gradient(145deg, rgba(251, 113, 133, 0.95), rgba(239, 68, 68, 0.82));
}

.ornament-drag-ghost.ornament-bell {
  background: linear-gradient(145deg, rgba(250, 204, 21, 0.94), rgba(245, 158, 11, 0.84));
}

.ornament-drag-ghost.ornament-leaf {
  background: linear-gradient(145deg, rgba(16, 185, 129, 0.9), rgba(5, 150, 105, 0.82));
}

.ornament-drag-ghost.ornament-feather {
  background: linear-gradient(145deg, rgba(129, 140, 248, 0.92), rgba(99, 102, 241, 0.82));
}

.ornament-drag-ghost-symbol {
  font-size: 26px;
  line-height: 1;
  color: rgba(255, 255, 255, 0.96);
  font-weight: 600;
}

.writing-ambient-panel.is-writing-focused {
  transform: translateY(-2rpx);
  border-color: rgba(251, 191, 36, 0.3);
  box-shadow: 0 14rpx 30rpx rgba(234, 179, 8, 0.18);
}

.writing-ambient-panel.low-perf .desk-lamp-glow {
  animation: none;
  opacity: 0.72;
}

.desk-lamp-glow {
  position: absolute;
  top: -48rpx;
  right: -34rpx;
  width: 210rpx;
  height: 210rpx;
  pointer-events: none;
  background: radial-gradient(circle, rgba(254, 240, 138, 0.56), rgba(255, 255, 255, 0));
  animation: lamp-glow-breathe 4.6s ease-in-out infinite;
}

.writing-ambient-copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.writing-ambient-title {
  font-size: 25rpx;
  color: #854d0e;
  font-weight: 600;
}

.writing-ambient-subtitle {
  font-size: 20rpx;
  color: #78716c;
  line-height: 1.6;
}

.writing-ambient-subtitle.is-updating {
  animation: ambient-subtitle-refresh 0.7s ease;
}

@keyframes ambient-subtitle-refresh {
  0% {
    opacity: 0;
    transform: translateY(8rpx) scale(0.98);
    filter: blur(2rpx);
  }
  55% {
    opacity: 1;
    transform: translateY(0) scale(1.02);
    filter: blur(0);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }
}

@keyframes blindbox-quote-reveal {
  from {
    opacity: 0;
    transform: translateY(8rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes lamp-glow-breathe {
  0%,
  100% {
    opacity: 0.68;
    transform: scale(0.98);
  }

  50% {
    opacity: 0.92;
    transform: scale(1.04);
  }
}

@keyframes ornament-sway {
  0%,
  100% {
    transform: rotate(-5deg);
  }

  50% {
    transform: rotate(5deg);
  }
}

@keyframes tassel-swing {
  0%,
  100% {
    transform: rotate(-14deg) translateX(-1rpx);
  }

  50% {
    transform: rotate(14deg) translateX(1rpx);
  }
}

