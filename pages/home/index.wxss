.writing-main {
  flex: 1;
  height: 100%;
  min-height: 0;
  min-width: 0;
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
}

.writing-light-fx-layer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: 1;
  background: transparent !important;
}

.writing-light-beam,
.writing-light-glow {
  position: absolute;
  pointer-events: none;
}

.writing-light-beam {
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 0;
  transform-origin: center;
  will-change: opacity, filter;
}

.writing-light-glow {
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  will-change: opacity;
}

.writing-paper {
  flex: 1;
  min-height: 0;
  position: relative;
  z-index: 2;
}

.writing-workspace.writing-light-enabled .writing-paper {
  background-color: rgba(255, 255, 255, 0.9);
}



.writing-right-rail {
  position: fixed;
  right: 22rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 88rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  z-index: 35;
}

.right-entry-card {
  min-height: 76rpx;
  justify-content: center;
}

.publish-entry-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  min-height: 94rpx;
  padding: 8rpx 4rpx;
  box-sizing: border-box;
}

.publish-entry-text {
  font-size: 22rpx;
  font-weight: 500;
  text-align: center;
}

.publish-entry-card.enabled {
  transform: translateY(-2rpx) scale(1.04) !important;
  filter: saturate(1.2) !important;
  background: rgba(99, 102, 241, 0.1) !important;
  border-radius: 18rpx !important;
  border: 2rpx solid rgba(99, 102, 241, 0.6) !important;
  box-shadow: 0 0 20rpx rgba(99, 102, 241, 0.4) !important;
}

.publish-entry-card.enabled .left-entry-icon {
  transform: scale(1.06) !important;
  box-shadow:
    0 10rpx 22rpx rgba(99, 102, 241, 0.3),
    0 0 22rpx rgba(99, 102, 241, 0.4) !important;
}

/* 确保只有发布按钮高亮，其他按钮变灰 */
.writing-workspace.writing-focused .writing-right-rail {
  transform: translateY(-50%) scale(0.96);
}

.writing-workspace.writing-focused .writing-right-rail .left-entry-card:not(.publish-entry-card) {
  opacity: 0.46;
}

.writing-workspace.writing-focused .publish-entry-card {
  opacity: 1 !important;
  transform: none !important;
  filter: saturate(1) !important;
}

.writing-workspace.writing-focused .publish-entry-card.enabled {
  opacity: 1 !important;
  transform: translateY(-2rpx) scale(1.04) !important;
  filter: saturate(1.2) !important;
  background: rgba(99, 102, 241, 0.1) !important;
  border: 2rpx solid rgba(99, 102, 241, 0.6) !important;
  box-shadow: 0 0 20rpx rgba(99, 102, 241, 0.4) !important;
}

.writing-workspace.writing-focused .publish-entry-card.enabled .left-entry-icon {
  opacity: 1 !important;
  transform: scale(1.06) !important;
  filter: none !important;
  box-shadow:
    0 10rpx 22rpx rgba(99, 102, 241, 0.3),
    0 0 22rpx rgba(99, 102, 241, 0.4) !important;
}

@keyframes side-entry-breathe {
  0%,
  100% {
    transform: translateY(0) scale(1);
    box-shadow: 0 8rpx 18rpx rgba(148, 163, 184, 0.16);
  }
  50% {
    transform: translateY(-4rpx) scale(1.03);
    box-shadow: 0 14rpx 24rpx rgba(99, 102, 241, 0.18);
  }
}

@keyframes blindbox-entry-shake {
  0% { transform: rotate(0deg) scale(1); }
  20% { transform: rotate(-6deg) scale(1.03); }
  40% { transform: rotate(6deg) scale(1.03); }
  60% { transform: rotate(-4deg) scale(1.02); }
  80% { transform: rotate(4deg) scale(1.01); }
  100% { transform: rotate(0deg) scale(1); }
}

