<view class="container" style="background-color: {{theme.bgColor}};">
  <!-- 用户信息区 -->
  <view class="user-info-section">
    <view class="avatar-wrapper">
      <view class="avatar" style="background: linear-gradient(145deg, {{theme.primaryColor}}, {{theme.primaryColor}}cc);">
        <text class="avatar-text">{{userInfo.nickname.charAt(0)}}</text>
      </view>
      <view class="avatar-edit-btn" style="background-color: {{theme.primaryColor}};">
        <text class="edit-icon">🖌️</text>
      </view>
    </view>
    <view class="user-details">
      <text class="nickname" style="color: {{textPalette.title}};">{{userInfo.nickname}}</text>
      <text class="mood" style="color: {{textPalette.subtitle}};">{{userInfo.mood}}</text>
    </view>
    <view class="notification-btn" bindtap="onNotificationTap">
      <text class="notification-icon">🔔</text>
      <view wx:if="{{unreadNotificationCount > 0}}" class="notification-badge" style="background-color: {{theme.primaryColor}};">
        <text class="notification-count">{{unreadNotificationCount}}</text>
      </view>
    </view>
  </view>

  <!-- Tab 切换 -->
  <view class="tabs-section">
    <view class="tabs">
      <view class="tab {{activeTab === 'topics' ? 'active' : ''}}" bindtap="switchTab" data-tab="topics">
        <text class="tab-text" style="color: {{activeTab === 'topics' ? theme.primaryColor : textPalette.subtitle}};">话题</text>
      </view>
      <view class="tab {{activeTab === 'ai' ? 'active' : ''}}" bindtap="switchTab" data-tab="ai">
        <text class="tab-text" style="color: {{activeTab === 'ai' ? theme.primaryColor : textPalette.subtitle}};">智能体</text>
      </view>
      <view class="tab {{activeTab === 'likes' ? 'active' : ''}}" bindtap="switchTab" data-tab="likes">
        <text class="tab-text" style="color: {{activeTab === 'likes' ? theme.primaryColor : textPalette.subtitle}};">点赞</text>
      </view>
      <view class="tab {{activeTab === 'favorites' ? 'active' : ''}}" bindtap="switchTab" data-tab="favorites">
        <text class="tab-text" style="color: {{activeTab === 'favorites' ? theme.primaryColor : textPalette.subtitle}};">收藏</text>
      </view>
    </view>
  </view>

  <!-- 话题页面 -->
  <view wx:if="{{activeTab === 'topics'}}" class="content-section">
    <scroll-view 
      class="content-list" 
      scroll-y="true" 
      scrollbar-hidden="true"
      refresher-enabled="{{true}}"
      refresher-triggered="{{topicsRefreshing}}"
      bindrefresherrefresh="onTopicsRefresh"
    >
      <!-- 空状态 -->
      <view wx:if="{{myTopicsList.length === 0}}" class="empty-state">
        <text class="empty-text" style="color: {{textPalette.subtitle}};">你还未发布话题</text>
        <view class="empty-action-btn" bindtap="goToWrite" style="background: linear-gradient(135deg, {{theme.primaryColor}}, #8b5cf6);">
          <text class="empty-action-text">去发布</text>
        </view>
      </view>

      <!-- 话题列表 -->
      <view wx:else class="post-list">
        <view wx:for="{{myTopicsList}}" wx:key="id" class="post-card" style="background-color: {{theme.cardColor}};" bindtap="onOpenPostDetail" data-id="{{item.id}}" data-type="topic">
          <view wx:if="{{item.title}}" class="post-card-title" style="color: {{textPalette.title}};">
            <view class="title-bar" style="background-color: {{theme.primaryColor}};"></view>
            {{item.title}}
          </view>
          
          <view class="post-card-content" style="color: {{textPalette.body}};">{{item.content}}</view>
          
          <view wx:if="{{item.location}}" class="post-card-meta" style="color: {{textPalette.subtitle}};">
            <text>📍 {{item.location}}</text>
          </view>
          
          <view wx:if="{{item.blindBoxQuote}}" class="post-card-quote" style="color: {{theme.primaryColor}};">「{{item.blindBoxQuote}}」</view>
          
          <view class="post-card-footer">
            <view class="post-stats">
              <text class="stat-item">🤍 {{item.likeCount || 0}}</text>
              <text class="stat-item">⭐ {{item.collectCount || 0}}</text>
              <text class="stat-item">💬 {{item.commentCount || 0}}</text>
            </view>
            <view class="post-actions">
              <text class="post-delete" bindtap="onDeletePost" data-id="{{item.id}}">删除</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 智能体页面 -->
  <view wx:if="{{activeTab === 'ai'}}" class="content-section">
    <scroll-view class="content-list" scroll-y="true" scrollbar-hidden="true">
      <view class="empty-state">
        <text class="empty-text" style="color: {{textPalette.subtitle}};">智能体功能开发中</text>
      </view>
    </scroll-view>
  </view>

  <!-- 点赞页面 -->
  <view wx:if="{{activeTab === 'likes'}}" class="content-section">
    <scroll-view 
      class="content-list" 
      scroll-y="true" 
      scrollbar-hidden="true"
      refresher-enabled="{{true}}"
      refresher-triggered="{{likesRefreshing}}"
      bindrefresherrefresh="onLikesRefresh"
    >
      <!-- 空状态 -->
      <view wx:if="{{likedList.length === 0}}" class="empty-state">
        <text class="empty-text" style="color: {{textPalette.subtitle}};">你还没有点赞内容</text>
        <view class="empty-action-btn" bindtap="goToSquare" style="background: linear-gradient(135deg, {{theme.primaryColor}}, #8b5cf6);">
          <text class="empty-action-text">去动态</text>
        </view>
      </view>

      <!-- 点赞列表 -->
      <view wx:else class="post-list">
        <view wx:for="{{likedList}}" wx:key="id" class="post-card" style="background-color: {{theme.cardColor}};" bindtap="onOpenSquarePostDetail" data-id="{{item.id}}">
          <view class="post-card-header">
            <view class="post-user-info">
              <view class="user-avatar-small" style="background: linear-gradient(145deg, {{theme.primaryColor}}, {{theme.primaryColor}}cc);">
                <text class="user-avatar-text-small">{{item.nickname ? item.nickname.charAt(0) : '匿'}}</text>
              </view>
              <text class="user-nickname-small" style="color: {{textPalette.title}};">{{item.nickname || '匿名用户'}}</text>
            </view>
          </view>
          
          <view wx:if="{{item.title}}" class="post-card-title" style="color: {{textPalette.title}};">
            <view class="title-bar" style="background-color: {{theme.primaryColor}};"></view>
            {{item.title}}
          </view>
          
          <view class="post-card-content" style="color: {{textPalette.body}};">{{item.content}}</view>
          
          <view wx:if="{{item.location}}" class="post-card-meta" style="color: {{textPalette.subtitle}};">
            <text>📍 {{item.location}}</text>
          </view>
          
          <view wx:if="{{item.blindBoxQuote}}" class="post-card-quote" style="color: {{theme.primaryColor}};">「{{item.blindBoxQuote}}」</view>
          
          <view class="post-card-footer">
            <text class="post-time" style="color: {{textPalette.subtitle}};">{{item.time}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 收藏页面 -->
  <view wx:if="{{activeTab === 'favorites'}}" class="content-section">
    <scroll-view 
      class="content-list" 
      scroll-y="true" 
      scrollbar-hidden="true"
      refresher-enabled="{{true}}"
      refresher-triggered="{{favoritesRefreshing}}"
      bindrefresherrefresh="onFavoritesRefresh"
    >
      <!-- 空状态 -->
      <view wx:if="{{favoriteList.length === 0}}" class="empty-state">
        <text class="empty-text" style="color: {{textPalette.subtitle}};">你还没有收藏内容</text>
        <view class="empty-action-btn" bindtap="goToSquare" style="background: linear-gradient(135deg, {{theme.primaryColor}}, #8b5cf6);">
          <text class="empty-action-text">去动态</text>
        </view>
      </view>

      <!-- 收藏列表 -->
      <view wx:else class="post-list">
        <view wx:for="{{favoriteList}}" wx:key="id" class="post-card" style="background-color: {{theme.cardColor}};" bindtap="onOpenSquarePostDetail" data-id="{{item.id}}">
          <view class="post-card-header">
            <view class="post-user-info">
              <view class="user-avatar-small" style="background: linear-gradient(145deg, {{theme.primaryColor}}, {{theme.primaryColor}}cc);">
                <text class="user-avatar-text-small">{{item.nickname ? item.nickname.charAt(0) : '匿'}}</text>
              </view>
              <text class="user-nickname-small" style="color: {{textPalette.title}};">{{item.nickname || '匿名用户'}}</text>
            </view>
          </view>
          
          <view wx:if="{{item.title}}" class="post-card-title" style="color: {{textPalette.title}};">
            <view class="title-bar" style="background-color: {{theme.primaryColor}};"></view>
            {{item.title}}
          </view>
          
          <view class="post-card-content" style="color: {{textPalette.body}};">{{item.content}}</view>
          
          <view wx:if="{{item.location}}" class="post-card-meta" style="color: {{textPalette.subtitle}};">
            <text>📍 {{item.location}}</text>
          </view>
          
          <view wx:if="{{item.blindBoxQuote}}" class="post-card-quote" style="color: {{theme.primaryColor}};">「{{item.blindBoxQuote}}」</view>
          
          <view class="post-card-footer">
            <text class="post-time" style="color: {{textPalette.subtitle}};">{{item.time}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 自定义底部导航栏 -->
  <view class="custom-tabbar" style="background-color: {{theme.cardColor}};">
    <view class="tabbar-item" bindtap="switchPage" data-page="home">
      <text class="tabbar-icon">💬</text>
      <text class="tabbar-text" style="color: {{textPalette.subtitle}};">对话</text>
    </view>
    <view class="tabbar-item">
      <text class="tabbar-icon">🤖</text>
      <text class="tabbar-text" style="color: {{textPalette.subtitle}};">智能体</text>
    </view>
    <view class="tabbar-item" bindtap="switchPage" data-page="square">
      <text class="tabbar-icon">#</text>
      <text class="tabbar-text" style="color: {{textPalette.subtitle}};">话题</text>
    </view>
    <view class="tabbar-item active">
      <text class="tabbar-icon">👤</text>
      <text class="tabbar-text" style="color: {{theme.primaryColor}};">我的</text>
    </view>
  </view>
</view>
