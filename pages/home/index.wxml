<view class="container ambient-breathing scene-{{activeScene}} ambient-time-{{ambientTimeSlot}} {{isRainModeEnabled ? 'rain-mode-on' : ''}} {{rainPerfLevel === 'low' ? 'rain-perf-low' : ''}} {{isSceneEntering ? 'scene-entering' : ''}}" style="background-color: {{theme.bgColor}};">
  <canvas
    wx:if="{{isShredCanvasVisible}}"
    id="homeShredCanvas"
    type="2d"
    class="shred-canvas"
  ></canvas>

  <view wx:if="{{currentPage === 0}}" class="immersive-scene-overlay" aria-hidden="true">
    <view
      wx:for="{{sceneParticles}}"
      wx:key="id"
      class="scene-particle kind-{{item.kind}}"
      style="left: {{item.left}}%; top: {{item.top}}%; width: {{item.size}}rpx; height: {{item.size}}rpx; opacity: {{item.opacity}}; animation-duration: {{item.duration}}ms; animation-delay: {{item.delay}}ms;"
    ></view>
  </view>

  <view wx:if="{{isRainModeEnabled && currentPage === 0}}" class="rain-overlay" aria-hidden="true">
    <view
      wx:for="{{rainDrops}}"
      wx:key="id"
      class="rain-drop"
      style="left: {{item.left}}%; height: {{item.height}}rpx; animation-duration: {{item.duration}}ms; animation-delay: {{item.delay}}ms; opacity: {{item.opacity}};"
    ></view>
  </view>

  <view wx:if="{{currentPage === 0}}" class="ambient-time-layer slot-{{ambientTimeSlot}}" aria-hidden="true"></view>

  <view wx:if="{{isSceneEntering && currentPage === 0}}" class="scene-enter-curtain" aria-hidden="true"></view>
  <view
    wx:if="{{showSceneRestoreHint && currentPage === 0}}"
    class="scene-restore-hint scene-{{sceneRestoreHintScene}}"
    aria-live="polite"
  >
    {{sceneRestoreHintText}}
  </view>

  <!-- 页面容器（改为非 swiper，彻底禁用跟手横滑） -->
  <view class="page-swiper">
    <!-- 心语页面 -->
    <view wx:if="{{currentPage === 0}}">
      <view class="page-container">
        <!-- 写作场景 -->
        <view class="writing-workspace theme-{{activeThemeType}} {{isWritingFocused ? 'writing-focused' : ''}}">
          <view class="writing-left-rail">
            <view
              id="companionNestSlot"
              class="left-entry-card companion-nest-card {{companionNestHighlighted ? 'is-highlighted' : ''}}"
              bindtap="onTapCompanionNest"
            >
              <view class="companion-nest-shell">
                <view wx:if="{{companionInNest}}" class="companion-nest-resting-sprite {{companionVisualType}}" style="background-color: {{theme.primaryColor}};">
                  <view class="companion-eye left"></view>
                  <view class="companion-eye right"></view>
                </view>
                <text wx:else class="companion-nest-emoji">🏡</text>
              </view>
              <text class="companion-nest-label" style="color: {{textPalette.subtitle}};">{{companionInNest ? '休息中' : '点击回窝'}}</text>
            </view>

            <view id="toolEntryOrnament" class="left-entry-card {{activeToolPanel === 'ornament' ? 'is-active' : ''}}" bindtap="onSelectHangingOrnament">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'ornament' ? 14 : 8}}rpx {{theme.primaryColor}});">🪢</text>
            </view>

            <view id="toolEntryTheme" class="left-entry-card {{activeToolPanel === 'theme' ? 'is-active' : ''}}" bindtap="onTapToolTheme">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'theme' ? 14 : 8}}rpx {{theme.primaryColor}});">🎨</text>
            </view>

            <view id="toolEntryBlindbox" class="left-entry-card {{activeToolPanel === 'blindbox' ? 'is-active' : ''}}" bindtap="onTapToolBlindBox">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'blindbox' ? 14 : 8}}rpx {{theme.primaryColor}});">🎁</text>
            </view>

            <view id="toolEntryPackage" class="left-entry-card {{activeToolPanel === 'package' ? 'is-active' : ''}}" bindtap="onTapToolPackage">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'package' ? 14 : 8}}rpx {{theme.primaryColor}});">📦</text>
            </view>

            <view class="left-entry-card" bindtap="toggleBreathingGuide">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{isBreathingActive ? 14 : 8}}rpx {{theme.primaryColor}});">🧘</text>
            </view>
          </view>

          <view class="writing-main">
            <view class="hanging-hook-zone {{isOrnamentHookHighlighted ? 'is-highlighted' : ''}}" aria-label="挂件挂钩区域">
              <view class="hanging-hook"></view>
              <view class="hanging-line"></view>
              <view class="hanging-ornament ornament-{{selectedHangingOrnament}}" style="animation-duration: {{ornamentSwayDuration}}s;">
                <text class="hanging-ornament-core">{{hangingOrnamentSymbol}}</text>
                <view class="hanging-tassels">
                  <view class="ornament-tassel-strand left"></view>
                  <view class="ornament-tassel-strand center"></view>
                  <view class="ornament-tassel-strand right"></view>
                </view>
              </view>
              <text class="hanging-ornament-label" style="color: {{textPalette.subtitle}};">{{hangingOrnamentLabel}}</text>
            </view>

            <view wx:if="{{writingLightEnabled}}" class="writing-light-fx-layer" aria-hidden="true">
              <view class="writing-light-beam" style="{{writingLightBeamStyle}}"></view>
              <view class="writing-light-glow" style="{{writingLightGlowStyle}}"></view>
            </view>

            <view class="writing-paper {{activePostType}}" style="background-color: {{theme.cardColor}}; background-image: linear-gradient(160deg, {{theme.cardColor}}, {{theme.bgColor}}); box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
              <view class="paper-header type-{{activePostType}}">
                <view class="paper-type-banner">
                  <text class="paper-type-icon">{{activePostType === 'letter' ? '✉️' : (activePostType === 'postcard' ? '🖼️' : (activePostType === 'diary' ? '📔' : '🎬'))}}</text>
                  <text class="paper-title" style="color: {{textPalette.title}};">{{activePostType === 'letter' ? '写信' : (activePostType === 'postcard' ? '明信片' : (activePostType === 'diary' ? '日记' : '分镜脚本模板'))}}</text>
                </view>
                <text class="paper-subtitle {{isAmbientSubtitleAnimating ? 'is-updating' : ''}}" style="color: {{textPalette.subtitle}};">{{writingAmbientSubtitle}}</text>

                <view wx:if="{{activePostType === 'letter'}}">
                  <text class="diary-date" style="color: {{textPalette.subtitle}};">{{writingDateText}}</text>
                </view>

                <view wx:if="{{activePostType === 'letter'}}" class="letter-salutation-row">
                  <input
                    class="letter-salutation-input"
                    placeholder="称呼（如：亲爱的自己）"
                    value="{{letterSalutation}}"
                    bindinput="onLetterSalutationInput"
                  />
                </view>

                <view wx:if="{{activePostType === 'postcard'}}" class="postcard-head-meta">
                  <text class="postcard-stamp">AIR MAIL</text>
                  <text class="diary-date" style="color: {{textPalette.subtitle}};">{{writingDateText}}</text>
                  <input class="immersive-input postcard-location-input" placeholder="地点戳（如：杭州 · 西湖边）" value="{{postcardLocation}}" bindinput="onPostcardLocationInput" />
                </view>

                <view wx:if="{{activePostType === 'diary'}}" class="diary-head-meta">
                  <text class="diary-date" style="color: {{textPalette.subtitle}};">{{writingDateText}}</text>
                  <input class="immersive-input diary-weather-input" placeholder="天气（如：小雨 / 晴天）" value="{{diaryWeather}}" bindinput="onDiaryWeatherInput" />
                  <view class="mood-score-row diary-mood-row">
                    <text class="mood-score-label" style="color: {{textPalette.subtitle}};">今日心情</text>
                    <slider min="1" max="10" step="1" value="{{diaryMoodScore}}" activeColor="{{theme.primaryColor}}" backgroundColor="#E5E7EB" block-size="16" bindchange="onDiaryMoodScoreChange" />
                    <text class="mood-score-value" style="color: {{textPalette.subtitle}};">{{diaryMoodScore}}/10</text>
                  </view>
                </view>


              </view>

              <scroll-view class="paper-body-scroll type-{{activePostType}}" scroll-y="true" scrollbar-hidden="true" style="background: linear-gradient(to bottom, {{theme.cardColor}}, {{theme.bgColor}});">
                <view class="paper-body {{isPostShattering ? 'post-shattering' : ''}} {{isWritingFocused ? 'writing-focused' : ''}} type-{{activePostType}}" style="background: linear-gradient(160deg, {{theme.cardColor}}, {{theme.bgColor}});">
                  <textarea
                    id="homePostInputField"
                    class="paper-textarea input-{{activePostType}}"
                    placeholder="{{postPlaceholder}}"
                    placeholder-style="color: {{textPalette.tertiary}};"
                    value="{{postContent}}"
                    bindinput="onPostInput"
                    bindfocus="onPostFocus"
                    bindblur="onPostBlur"
                    style="color: {{textPalette.body}};"
                    maxlength="-1"
                  ></textarea>
                </view>
              </scroll-view>

              <view class="paper-footer type-{{activePostType}}" wx:if="{{activePostType === 'letter'}}">
                <text class="paper-footer-line" style="color: {{textPalette.body}};">此致</text>
                <text class="paper-footer-line" style="color: {{textPalette.body}};">敬礼</text>
                <input
                  class="letter-signature-input"
                  placeholder="落款（如：—— 深夜里的你）"
                  value="{{letterSignature}}"
                  bindinput="onLetterSignatureInput"
                />
              </view>

              <view class="paper-footer type-{{activePostType}}" wx:if="{{activePostType === 'postcard'}}">
                <text class="paper-footer-line" style="color: {{textPalette.subtitle}};">寄出地：{{postcardLocation || '未填写'}}</text>
              </view>

              <view class="paper-footer type-{{activePostType}}" wx:if="{{activePostType === 'diary'}}">
                <text class="paper-footer-line" style="color: {{textPalette.subtitle}};">天气：{{diaryWeather || '未填写'}} · 心情分：{{diaryMoodScore}}/10</text>
              </view>



            </view>
          </view>

          <view class="writing-right-rail">
            <view id="toolEntryTemplate" class="left-entry-card right-entry-card {{activeToolPanel === 'template' ? 'is-active' : ''}}" bindtap="onTapToolTemplate">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'template' ? 14 : 8}}rpx {{theme.primaryColor}});">🧩</text>
            </view>

            <view class="left-entry-card right-entry-card {{isAudioPlaying ? 'is-active' : ''}}" bindtap="toggleAudioPlay">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{isAudioPlaying ? 14 : 8}}rpx {{theme.primaryColor}});">{{isAudioPlaying ? '⏸' : '▶'}}</text>
            </view>

            <view class="left-entry-card right-entry-card {{isRainModeEnabled ? 'is-active' : ''}}" bindtap="toggleRainMode">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{isRainModeEnabled ? 14 : 8}}rpx {{theme.primaryColor}});">🌧️</text>
            </view>

            <view id="toolEntryVolume" class="left-entry-card right-entry-card {{activeToolPanel === 'volume' ? 'is-active' : ''}}" bindtap="onTapToolVolume">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'volume' ? 14 : 8}}rpx {{theme.primaryColor}});">🔊</text>
            </view>

            <view id="toolEntryScene" class="left-entry-card right-entry-card {{activeToolPanel === 'scene' ? 'is-active' : ''}}" bindtap="onTapToolScene">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'scene' ? 14 : 8}}rpx {{theme.primaryColor}});">🌌</text>
            </view>

            <view id="toolEntryIntensity" class="left-entry-card right-entry-card {{activeToolPanel === 'intensity' ? 'is-active' : ''}}" bindtap="onTapToolIntensity">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'intensity' ? 14 : 8}}rpx {{theme.primaryColor}});">🎚️</text>
            </view>

            <view id="toolEntryLight" class="left-entry-card right-entry-card {{activeToolPanel === 'light' ? 'is-active' : ''}}" bindtap="onTapToolLight">
              <text class="left-entry-icon" style="filter: drop-shadow(0 0 {{activeToolPanel === 'light' ? 14 : 8}}rpx {{theme.primaryColor}});">💡</text>
            </view>
          </view>

          <view wx:if="{{activeToolPanel}}" class="mini-tool-mask" bindtap="closeToolPanel"></view>

          <view wx:if="{{activeToolPanel === 'template' || activeToolPanel === 'volume' || activeToolPanel === 'scene' || activeToolPanel === 'intensity' || activeToolPanel === 'light'}}" class="mini-tool-pop right panel-{{activeToolPanel}}" catchtap="onTapToolPanelBody" style="top: {{miniToolTopPx}}px; background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
            <view class="mini-tool-head">
              <text class="mini-tool-title" style="color: {{textPalette.title}};">{{activeToolPanel === 'template' ? '写作' : (activeToolPanel === 'volume' ? '音量' : (activeToolPanel === 'scene' ? '场景' : (activeToolPanel === 'intensity' ? '强度' : '灯光')))}}</text>
              <text class="mini-tool-close" bindtap="closeToolPanel" style="color: {{theme.primaryColor}};">收起</text>
            </view>

            <view wx:if="{{activeToolPanel === 'template'}}" class="mini-tool-body">
              <view class="template-option-list">
                <view
                  wx:for="{{postTypes}}"
                  wx:key="key"
                  class="template-option-item {{activePostType === item.key ? 'active' : ''}}"
                  bindtap="switchPostType"
                  data-type="{{item.key}}"
                >
                  <text class="template-option-icon">{{item.icon}}</text>
                  <view class="template-option-copy">
                    <text class="template-option-label" style="color: {{activePostType === item.key ? theme.primaryColor : textPalette.body}};">{{item.label}}</text>
                    <text class="template-option-tagline" style="color: {{textPalette.subtitle}};">{{item.tagline}}</text>
                  </view>
                </view>
              </view>
            </view>

            <view wx:if="{{activeToolPanel === 'volume'}}" class="mini-tool-body">
              <view class="audio-volume-row compact">
                <slider
                  class="audio-slider"
                  min="0"
                  max="100"
                  step="5"
                  value="{{audioVolume}}"
                  activeColor="{{theme.primaryColor}}"
                  backgroundColor="#E5E7EB"
                  block-size="16"
                  bindchange="onAudioVolumeChange"
                />
                <text class="audio-volume-value" style="color: {{textPalette.subtitle}};">{{audioVolume}}%</text>
              </view>
            </view>

            <view wx:if="{{activeToolPanel === 'scene'}}" class="mini-tool-body">
              <view class="scene-type-grid">
                <view
                  wx:for="{{sceneOptions}}"
                  wx:key="key"
                  class="scene-type-chip scene-{{item.key}} {{activeScene === item.key ? 'active' : ''}}"
                  bindtap="onSceneChange"
                  data-scene="{{item.key}}"
                >
                  <text class="scene-type-chip-icon">{{item.icon}}</text>
                  <text class="scene-type-chip-label">{{item.label}}</text>
                </view>
              </view>
            </view>

            <view wx:if="{{activeToolPanel === 'intensity'}}" class="mini-tool-body">
              <view class="scene-intensity-row compact">
                <slider
                  class="scene-intensity-slider"
                  min="20"
                  max="100"
                  step="5"
                  value="{{sceneIntensity}}"
                  activeColor="{{theme.primaryColor}}"
                  backgroundColor="#E5E7EB"
                  block-size="16"
                  bindchanging="onSceneIntensityChange"
                  bindchange="onSceneIntensityChange"
                />
                <text class="scene-intensity-value" style="color: {{textPalette.subtitle}};">{{sceneIntensity}}%</text>
              </view>
            </view>

            <view wx:if="{{activeToolPanel === 'light'}}" class="mini-tool-body mini-tool-body-light">
              <view class="writing-light-option-row writing-light-switch-row">
                <text class="writing-light-option-label" style="color: {{textPalette.subtitle}};">灯光</text>
                <switch
                  checked="{{writingLightEnabled}}"
                  color="{{theme.primaryColor}}"
                  bindchange="onWritingLightEnableChange"
                />
              </view>

              <view class="writing-light-option-row">
                <text class="writing-light-option-label" style="color: {{textPalette.subtitle}};">灯色</text>
                <view class="writing-light-chip-group">
                  <view class="writing-light-chip {{writingLightColorMode === 'warm' ? 'active' : ''}}" data-mode="warm" bindtap="onSwitchWritingLightColor">暖黄</view>
                  <view class="writing-light-chip {{writingLightColorMode === 'white' ? 'active' : ''}}" data-mode="white" bindtap="onSwitchWritingLightColor">白炙</view>
                </view>
              </view>

              <view class="writing-light-option-row">
                <text class="writing-light-option-label" style="color: {{textPalette.subtitle}};">方向</text>
                <view class="writing-light-chip-group">
                  <view class="writing-light-chip {{writingLightFromSide === 'left' ? 'active' : ''}}" data-side="left" bindtap="onSwitchWritingLightSide">左上</view>
                  <view class="writing-light-chip {{writingLightFromSide === 'right' ? 'active' : ''}}" data-side="right" bindtap="onSwitchWritingLightSide">右上</view>
                </view>
              </view>

            </view>
          </view>

          <view wx:if="{{activeToolPanel === 'theme'}}" class="mini-tool-pop left theme panel-theme" catchtap="onTapToolPanelBody" style="top: {{miniToolTopPx}}px; background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
            <view class="mini-tool-head">
              <text class="mini-tool-title" style="color: {{textPalette.title}};">主题设置</text>
              <text class="mini-tool-close" bindtap="closeToolPanel" style="color: {{theme.primaryColor}};">收起</text>
            </view>
            <view class="mini-tool-body">
              <view class="theme-tabs compact" style="background-color: {{theme.cardColor}};">
                <view class="theme-tab {{activeThemeType === themeStyleTypes.FEMALE ? 'active' : ''}}" bindtap="switchThemeType" data-type="{{themeStyleTypes.FEMALE}}" style="background-color: {{activeThemeType === themeStyleTypes.FEMALE ? theme.primaryColor : ''}}; color: {{activeThemeType === themeStyleTypes.FEMALE ? textPalette.inverse : textPalette.title}};">
                  柔美
                </view>
                <view class="theme-tab {{activeThemeType === themeStyleTypes.MALE ? 'active' : ''}}" bindtap="switchThemeType" data-type="{{themeStyleTypes.MALE}}" style="background-color: {{activeThemeType === themeStyleTypes.MALE ? theme.primaryColor : ''}}; color: {{activeThemeType === themeStyleTypes.MALE ? textPalette.inverse : textPalette.title}};">
                  深邃
                </view>
              </view>
              <view class="theme-list compact">
                <view class="theme-item compact" wx:for="{{filteredThemes}}" wx:key="item.id" bindtap="selectTheme" data-theme="{{item}}">
                  <view class="theme-color" style="background-color: {{item.primaryColor}};">
                    <text class="theme-name">{{item.name}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>

          <view wx:if="{{activeToolPanel === 'package'}}" class="mini-tool-pop left package panel-package" catchtap="onTapToolPanelBody" style="top: {{miniToolTopPx}}px; background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
            <view class="mini-tool-head">
              <text class="mini-tool-title" style="color: {{textPalette.title}};">完成写作</text>
              <text class="mini-tool-close" bindtap="closeToolPanel" style="color: {{theme.primaryColor}};">收起</text>
            </view>
            <view class="mini-tool-body package-tool-grid">
              <view class="package-tool-item" data-type="letter" bindtap="onSelectPackageType">
                <text class="package-tool-icon">✉️</text>
                <text class="package-tool-label">封装信封</text>
              </view>
              <view class="package-tool-item" data-type="postcard" bindtap="onSelectPackageType">
                <text class="package-tool-icon">🪪</text>
                <text class="package-tool-label">封装卡片</text>
              </view>
              <view class="package-tool-item" data-type="diary" bindtap="onSelectPackageType">
                <text class="package-tool-icon">📓</text>
                <text class="package-tool-label">封装日志</text>
              </view>

            </view>
          </view>

          <view wx:if="{{activeToolPanel === 'blindbox'}}" class="mini-tool-pop left panel-blindbox" catchtap="onTapToolPanelBody" style="top: {{miniToolTopPx}}px; background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
            <view class="mini-tool-head">
              <text class="mini-tool-title" style="color: {{textPalette.title}};">解忧盲盒</text>
              <text class="mini-tool-close" bindtap="closeToolPanel" style="color: {{theme.primaryColor}};">收起</text>
            </view>
            <view class="mini-tool-body">
              <view class="blind-box-content" bindtap="onOpenBlindBoxFromPanel">
                <view class="blind-box-card {{isFlipping ? 'flipping' : ''}}">
                  <view class="blind-box-front" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
                    <text class="blind-box-icon {{blindBoxEntryShaking ? 'shake' : ''}}">🎁</text>
                    <text class="blind-box-text" style="color: {{textPalette.subtitle}};">点我抽一句</text>
                  </view>
                  <view class="blind-box-back" wx:if="{{showQuote}}" style="background-color: {{theme.primaryColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
                    <text class="blind-box-quote" style="color: {{textPalette.inverse}};">{{currentQuote}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>

          <view wx:if="{{activeToolPanel === 'ornament'}}" class="mini-tool-pop left ornament panel-ornament" catchtap="onTapToolPanelBody" style="top: {{miniToolTopPx}}px; background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
            <view class="mini-tool-head">
              <text class="mini-tool-title" style="color: {{textPalette.title}};">挂件更换</text>
              <text class="mini-tool-close" bindtap="closeToolPanel" style="color: {{theme.primaryColor}};">收起</text>
            </view>
            <view class="mini-tool-body">
              <text class="ornament-panel-tip" style="color: {{textPalette.subtitle}};">点击选中直接更换，或长按拖到右上挂钩更换</text>
              <view class="ornament-option-list">
                <view
                  wx:for="{{hangingOrnamentOptions}}"
                  wx:key="key"
                  class="ornament-option-item {{selectedHangingOrnament === item.key ? 'active' : ''}}"
                  data-key="{{item.key}}"
                  bindtap="onChooseHangingOrnament"
                  bindlongpress="onOrnamentOptionLongPress"
                  catchtouchmove="onOrnamentOptionTouchMove"
                  bindtouchend="onOrnamentOptionTouchEnd"
                  bindtouchcancel="onOrnamentOptionTouchCancel"
                >
                  <view class="ornament-option-badge ornament-{{item.key}}">
                    <text class="ornament-option-symbol">{{item.symbol}}</text>
                  </view>
                  <text class="ornament-option-label">{{item.label}}</text>
                </view>
              </view>
            </view>
          </view>

        </view>
      </view>
    </view>
    
    <!-- 广场页面 -->
    <view wx:if="{{currentPage === 1}}">
      <view class="page-container">
        <scroll-view class="square-post-list" scroll-y="true" scrollbar-hidden="true">
          <view class="post-card type-{{item.type}}" wx:for="{{squarePostList}}" wx:key="id" id="home-card-{{item.id}}" bindtap="onOpenSquarePostDetail" data-id="{{item.id}}" data-tab="square" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; border-radius: {{theme.borderRadius}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
            <view class="post-card-header">
              <view class="post-type-badge type-{{item.type}}" style="color: {{textPalette.body}};">{{item.typeIcon}} {{item.typeLabel}}</view>
              <text class="post-time" style="color: {{textPalette.tertiary}};">{{item.time}}</text>
            </view>

            <view wx:if="{{item.type === 'letter'}}" class="post-card-content type-letter">
              <text class="post-letter-salutation" style="color: {{textPalette.subtitle}};">{{item.letterSalutation || '亲爱的你'}}：</text>
              <text class="post-text" style="color: {{textPalette.body}};">{{item.content}}</text>
              <text class="post-letter-signature" style="color: {{textPalette.subtitle}};">{{item.letterSignature || '—— 来自此刻的心'}}</text>
            </view>

            <view wx:if="{{item.type === 'postcard'}}" class="post-card-content type-postcard">
              <view class="postcard-top-line">
                <text class="postcard-location" style="color: {{textPalette.subtitle}};">📍 {{item.postcardLocation || '未署名地点'}}</text>
                <text class="postcard-stamp-mini" style="color: {{textPalette.tertiary}};">POSTCARD</text>
              </view>
              <text class="post-text" style="color: {{textPalette.body}};">{{item.content}}</text>
            </view>

            <view wx:if="{{item.type === 'diary'}}" class="post-card-content type-diary">
              <view class="post-diary-meta">
                <text class="post-diary-pill" style="color: {{textPalette.subtitle}};">天气 {{item.diaryWeather || '未知'}}</text>
                <text class="post-diary-pill" style="color: {{textPalette.subtitle}};">心情 {{item.diaryMoodScore || '--'}}/10</text>
              </view>
              <text class="post-text" style="color: {{textPalette.body}};">{{item.content}}</text>
            </view>



            <view class="post-card-footer">
              <text class="post-card-enter-hint" style="color: {{textPalette.subtitle}};">点击进入内容详情</text>
            </view>
          </view>
        </scroll-view>
        <text class="square-subtitle bottom-fixed" style="color: {{textPalette.subtitle}};">分享你的心情，倾听他人的故事</text>
      </view>
    </view>
    
    <!-- 我的页面 -->
    <view wx:if="{{currentPage === 2}}">
      <view class="page-container">
        <!-- 大留白用户信息区 -->
        <view class="user-info">
          <view class="avatar-container">
            <view class="avatar" style="border: 4rpx solid {{theme.primaryColor}};">
              <text class="avatar-text" style="color: {{textPalette.title}};">{{userInfo.nickname.charAt(0)}}</text>
            </view>
          </view>
          <view class="user-details">
            <text class="nickname" style="color: {{textPalette.title}};">{{userInfo.nickname}}</text>
            <text class="mood" style="color: {{textPalette.subtitle}};">{{userInfo.mood}}</text>
          </view>
        </view>

        <view class="user-data-tabs">
          <view class="section-title" style="color: {{textPalette.title}};">用户数据</view>
          <view class="user-data-tab-row">
            <view class="user-data-tab" bindtap="goToMyPosts">
              <text class="user-data-icon">📝</text>
              <text class="user-data-text" style="color: {{textPalette.body}};">我的发布</text>
            </view>
            <view class="user-data-tab" bindtap="goToMyFavorites">
              <text class="user-data-icon">⭐</text>
              <text class="user-data-text" style="color: {{textPalette.body}};">我的收藏</text>
            </view>
            <view class="user-data-tab" bindtap="goToReliefRecords">
              <text class="user-data-icon">📚</text>
              <text class="user-data-text" style="color: {{textPalette.body}};">解忧记录</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showPackageConfirmDialog}}" class="package-dialog-mask" bindtap="closePackageConfirmDialog">
    <view class="package-dialog-card" catchtap="onTapToolPanelBody" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
      <text class="package-dialog-title" style="color: {{textPalette.title}};">准备封装「{{pendingPackageLabel}}」</text>
      <text class="package-dialog-desc" style="color: {{textPalette.subtitle}};">选择要执行的操作</text>
      <view class="package-dialog-actions">
        <view class="package-dialog-btn ghost" bindtap="onSaveDraftPackage">存草稿</view>
        <view class="package-dialog-btn primary" bindtap="onConfirmPackageStart">确认封装</view>
      </view>
    </view>
  </view>

  <view wx:if="{{showPackagingAnimation}}" class="package-anim-mask" aria-live="polite">
    <view class="package-anim-card">
      <text class="package-anim-icon">📦</text>
      <text class="package-anim-text" style="color: {{textPalette.title}};">正在封装中...</text>
    </view>
  </view>

  <view wx:if="{{isOrnamentDragging}}" class="ornament-drag-layer" aria-hidden="true">
    <view class="ornament-drag-ghost ornament-{{ornamentDraggingKey}}" style="{{ornamentDragStyle}}">
      <text class="ornament-drag-ghost-symbol">{{ornamentDraggingSymbol}}</text>
    </view>
  </view>

  <view wx:if="{{showPackagePublishDialog}}" class="package-dialog-mask" bindtap="closePackagePublishDialog">
    <view class="package-dialog-card" catchtap="onTapToolPanelBody" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
      <text class="package-dialog-title" style="color: {{textPalette.title}};">封装完成</text>
      <text class="package-dialog-desc" style="color: {{textPalette.subtitle}};">选择保存方式</text>
      <view class="package-dialog-actions">
        <view class="package-dialog-btn ghost" bindtap="onSavePackagedLocal">存本地</view>
        <view class="package-dialog-btn primary" bindtap="onPublishPackagedPost">发布广场</view>
      </view>
    </view>
  </view>

  <view wx:if="{{isBreathingActive}}" class="breathing-guide-panel" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border: ' + theme.borderStyle : ''}};">
    <text class="breathing-guide-title" style="color: {{textPalette.subtitle}};">呼吸岛屿 · 第{{breathingDisplayRound}}轮</text>
    <text class="breathing-guide-phase" style="color: {{textPalette.title}};">{{breathingGuideText}}</text>
    <text class="breathing-guide-tip" style="color: {{textPalette.tertiary}};">长按发布按钮保持引导，松手即可结束</text>
  </view>

  <view wx:if="{{!companionInNest}}" class="companion-trail-layer" aria-hidden="true">
    <view
      wx:for="{{companionTrailParticles}}"
      wx:key="id"
      class="companion-trail-dot"
      style="left: {{item.x}}px; top: {{item.y}}px; width: {{item.size}}rpx; height: {{item.size}}rpx; opacity: {{item.opacity}};"
    ></view>
  </view>

  <!-- 自定义底部导航栏 -->
  <view class="custom-tabbar" style="background-color: {{theme.cardColor}}; box-shadow: {{theme.shadow}}; {{theme.borderStyle ? 'border-top: ' + theme.borderStyle : ''}};">
    <view class="tabbar-item {{currentPage === 0 ? 'active' : ''}}" bindtap="switchPage" data-page="0">
      <text class="tabbar-icon" style="color: {{currentPage === 0 ? theme.primaryColor : textPalette.subtitle}};">📝</text>
      <text class="tabbar-text" style="color: {{currentPage === 0 ? theme.primaryColor : textPalette.subtitle}};">心语</text>
    </view>
    <view class="tabbar-item {{currentPage === 1 ? 'active' : ''}}" bindtap="switchPage" data-page="1">
      <text class="tabbar-icon" style="color: {{currentPage === 1 ? theme.primaryColor : textPalette.subtitle}};">🌍</text>
      <text class="tabbar-text" style="color: {{currentPage === 1 ? theme.primaryColor : textPalette.subtitle}};">广场</text>
    </view>
    <view class="tabbar-item {{currentPage === 2 ? 'active' : ''}}" bindtap="switchPage" data-page="2">
      <text class="tabbar-icon" style="color: {{currentPage === 2 ? theme.primaryColor : textPalette.subtitle}};">👤</text>
      <text class="tabbar-text" style="color: {{currentPage === 2 ? theme.primaryColor : textPalette.subtitle}};">我的</text>
    </view>
  </view>

  <view wx:if="{{!companionInNest}}" class="fab-movable-area" style="pointer-events: {{isCompanionSelected ? 'auto' : 'none'}};" catchtap="onTapScreenForCompanionMove">
    <view
      class="fab-movable-view"
      style="left: {{fabX}}px; top: {{fabY}}px;"
    >
      <view
        class="companion-wrapper"
        catchtap="onTapCompanion"
      >
        <view class="companion-sprite {{companionVisualType}} state-{{companionState}} drag-level-{{companionDragLevel}} {{companionIsShy ? 'is-shy' : ''}} {{isCompanionDragging ? 'dragging' : ''}} {{companionTapFeedback ? 'tap-feedback' : ''}} {{isCompanionSelected ? 'selected' : ''}}" style="background-color: {{theme.primaryColor}};">
            <view class="companion-eye left"></view>
            <view class="companion-eye right"></view>
          </view>
        <view wx:if="{{showCompanionBubble}}" class="companion-bubble side-{{companionBubbleSide}} vertical-{{companionBubbleVertical}}" style="background-color: {{theme.cardColor}}; color: {{textPalette.body}}; box-shadow: {{theme.shadow}};">{{companionBubbleText}}</view>
      </view>
    </view>
  </view>
</view>
