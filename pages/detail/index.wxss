.container {
  min-height: 100vh;
  position: relative;
  background-image: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
  padding-bottom: 140rpx;
}

.custom-background-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1;
}

.detail-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  padding: 0 22rpx 24rpx 0;
  display: flex;
  align-items: center;
  gap: 0rpx;
  z-index: 100;
  box-sizing: border-box;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.nav-back {
  width: 64rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.nav-back-icon {
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
}

.nav-user-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  height: 100%;
}

.nav-user-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.nav-user-avatar-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.nav-user-nickname {
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1;
}

.nav-center {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  line-height: 1;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  max-width: 300rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1;
}

.nav-right {
  width: 64rpx;
  flex-shrink: 0;
}

.detail-scroll {
  height: 100vh;
  padding: 88rpx 32rpx 32rpx;
  padding-top: calc(88rpx + env(safe-area-inset-top));
  box-sizing: border-box;
  position: relative;
  z-index: 10;
}

.owner-toolbar {
  padding: 24rpx 0;
  margin-bottom: 16rpx;
}

.owner-toolbar-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.owner-toolbar-title {
  font-size: 25rpx;
  font-weight: 600;
}

.owner-toolbar-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.owner-toolbar-btn {
  font-size: 21rpx;
}

.owner-toolbar-btn.primary {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #fff;
  background: #6366f1;
}

.owner-scene-panel {
  margin-top: 24rpx;
}

.owner-scene-label {
  display: block;
  font-size: 20rpx;
}

.owner-scene-chip-group {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.owner-scene-chip {
  font-size: 20rpx;
  line-height: 1;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #64748b;
  background: rgba(148, 163, 184, 0.16);
}

.owner-scene-chip.active {
  color: #fff;
  background: #6366f1;
}

.owner-scene-intensity-row {
  margin-top: 12rpx;
}

.detail-content-section {
  padding: 16rpx 0;
}

.detail-user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.user-details {
  flex: 1;
}

.user-nickname {
  font-size: 28rpx;
  font-weight: 600;
}

.detail-title-section {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  width: 100%;
  min-height: 52rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
  text-align: center;
}

.detail-meta-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-top: 64rpx;
}

.detail-time {
  font-size: 19rpx;
}

.detail-location {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
}

.location-icon {
  font-size: 24rpx;
}

.detail-content-text {
  display: block;
  font-size: 30rpx;
  line-height: 1.74;
  text-align: center;
}

.detail-content-input {
  width: 100%;
  min-height: 180rpx;
  font-size: 29rpx;
  line-height: 1.74;
}

.detail-writing-time {
  margin-top: 80rpx;
  display: flex;
  justify-content: center;
}

.detail-writing-time text {
  font-size: 20rpx;
}

.detail-meta-group {
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.detail-meta {
  font-size: 22rpx;
}

.detail-meta-input {
  width: 100%;
  min-height: 64rpx;
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #334155;
  background: rgba(148, 163, 184, 0.12);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  box-sizing: border-box;
}

.letter-edit-group {
  flex-direction: column;
}

.detail-meta-pill {
  font-size: 19rpx;
  border-radius: 999rpx;
  padding: 6rpx 12rpx;
  background: rgba(255, 255, 255, 0.66);
}

.vlog-shot-list {
  flex-direction: column;
  gap: 6rpx;
}

.detail-shot-line {
  font-size: 20rpx;
  line-height: 1.45;
}

.detail-quote {
  margin-top: 24rpx;
  margin-bottom: 0;
  font-size: 24rpx;
  font-style: italic;
  text-align: center;
  padding: 24rpx 0;
}

.interaction-section {
  padding: 24rpx 0;
  margin-top: 16rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.12);
}

.interaction-actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.interaction-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 32rpx;
  line-height: 1;
}

.white-star {
  color: #ffffff;
  filter: grayscale(100%) brightness(300%);
}

.comment-section {
  padding: 32rpx 0;
}

.comment-header {
  margin-bottom: 24rpx;
}

.comment-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.comment-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.12);
  display: flex;
  gap: 16rpx;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #6366f1, #6366f1cc);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.comment-avatar-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.comment-content-wrapper {
  flex: 1;
}

.comment-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.comment-user {
  font-size: 24rpx;
  font-weight: 600;
}

.comment-time {
  font-size: 18rpx;
}

.comment-text {
  font-size: 26rpx;
  line-height: 1.6;
}

.comment-reply-btn {
  margin-top: 12rpx;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.reply-icon {
  font-size: 20rpx;
}

.reply-text {
  font-size: 20rpx;
}

.comment-replies {
  margin-top: 16rpx;
  padding-left: 16rpx;
  border-left: 2rpx solid rgba(148, 163, 184, 0.2);
}

.reply-item {
  padding: 16rpx 0;
  display: flex;
  gap: 12rpx;
}

.reply-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #8b5cf6, #8b5cf6cc);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.reply-avatar-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

.reply-content-wrapper {
  flex: 1;
}

.reply-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.reply-user {
  font-size: 22rpx;
  font-weight: 600;
}

.reply-to {
  font-size: 20rpx;
}

.reply-time {
  font-size: 16rpx;
}

.reply-text {
  font-size: 24rpx;
  line-height: 1.5;
}

.comment-input-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 100;
  box-sizing: border-box;
}

.comment-input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 40rpx;
  background: rgba(148, 163, 184, 0.12);
  font-size: 28rpx;
}

.cancel-reply {
  padding: 8rpx 12rpx;
}

.cancel-reply-text {
  font-size: 24rpx;
}

.send-btn {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
}

.send-btn-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}


