.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  padding: 60rpx 48rpx;
}

.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 80rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 80rpx;
}

.avatar-gradient {
  width: 100%;
  height: 100%;
  border-radius: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 64rpx;
  font-weight: 500;
  color: #fff;
}

.form-section {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.form-item {
  position: relative;
}

.form-label {
  display: block;
  font-size: 28rpx;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input,
.form-textarea {
  width: 100%;
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 16rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

.form-input {
  min-height: 88rpx;
}

.form-textarea {
  height: 160rpx;
}

.form-count {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  font-size: 24rpx;
}

.save-button {
  margin-top: 48rpx;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  box-shadow: 0 12rpx 32rpx rgba(99, 102, 241, 0.3);
}

.save-button-text {
  font-size: 32rpx;
  font-weight: 600;
}
