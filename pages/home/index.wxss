}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.mood-calendar {
  display: flex;
  flex-wrap: wrap;
  margin: -7.5rpx;
}

.mood-day {
  width: calc(14.28% - 15rpx);
  height: 50rpx;
  margin: 7.5rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 20rpx;
  color: white;
  transition: all 0.3s ease;
}

.mood-day:hover {
  transform: scale(1.1);
}

.mood-date {
  font-size: 16rpx;
}

.content-list {
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 24rpx;
  transition:
    background-color 0.45s cubic-bezier(0.22, 1, 0.36, 1),
