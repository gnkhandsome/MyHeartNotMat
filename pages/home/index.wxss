    font-size: 20rpx;
  }
  
  .publish-button {
    width: 70rpx;
    height: 70rpx;
  }

  .fab-movable-view {
    width: 122rpx;
    height: 122rpx;
  }

  .companion-wrapper {
    right: -12rpx;
    top: -24rpx;
  }

  .companion-sprite {
    width: 46rpx;
    height: 46rpx;
  }

  .companion-bubble {
    min-width: 150rpx;
    max-width: 260rpx;
    font-size: 18rpx;
    padding: 8rpx 12rpx;
  }
  
  .publish-icon {
    font-size: 42rpx;
  }
  
  .user-info {
    padding: 30rpx;
  }
  
  .avatar {
